    if len < 6 { 0 }
    else { if cmd_char(0) == 99 { if cmd_char(1) == 97 { if cmd_char(2) == 108 { if cmd_char(3) == 99 { if cmd_char(4) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_calc() {
    // "calc <a><op><b>" — simple calculator
    // Find operator (skip "0x" prefix)
    let len = cmd_len()
    let mut i = 5
    let mut op = 0
    let mut op_pos = 0
    // Skip first number (digits, hex prefix)
    if cmd_char(5) == 48 {
        if cmd_char(6) == 120 {
            i = 7
        }
    }
    while i < len {
        let c = cmd_char(i)
        let is_op = 0
        if c == 43 { op = 1 op_pos = i }
        if c == 45 { if i > 7 { op = 2 op_pos = i } }
        if c == 42 { op = 3 op_pos = i }
        if c == 47 { op = 4 op_pos = i }
        if c == 38 { op = 5 op_pos = i }
        if c == 124 { op = 6 op_pos = i }
        if c == 94 { op = 7 op_pos = i }
        if op > 0 {
            if op_pos == i {
                i = len
            }
        }
        i = i + 1
    }
    let a = parse_num_from(5)
    if op > 0 {
        let b = parse_num_from(op_pos + 1)
        let mut result = 0
        if op == 1 { result = a + b }
        if op == 2 { result = a - b }
        if op == 3 { result = a * b }
        if op == 4 { if b != 0 { result = a / b } }
        if op == 5 { result = a & b }
        if op == 6 { result = a | b }
        if op == 7 { result = a ^ b }
        print_num(result)
        print(" (")
        print_hex32(result)
        println(")")
    } else {
        println("?")
    }
}

