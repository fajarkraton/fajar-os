fn cmd_rand() {
    // Pseudo-random using timer ticks as seed
    let t = timer_ticks()
    let r = ((t * 6364136223846793005) + 1442695040888963407) & 0x7FFFFFFF
    let val = r & 0xFFFF
    print_num(val)
    nl()
}

