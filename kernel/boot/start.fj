fn cmd_cat() {
    // "cat <filename>" — print file contents
    let len = cmd_len()
    let mut slot = 1
    let mut found = 0
    while slot < 16 {
        let base = 0x47008000 + slot * 128
        let ftype = volatile_read_u8(base + 63)
        if ftype == 1 {
            let mut match_ok = 1
            let mut j = 0
            let mut ni = 4
            while ni < len {
                if volatile_read_u8(base + j) != cmd_char(ni) {
                    match_ok = 0
                    ni = len
                }
                j = j + 1
                ni = ni + 1
            }
            if match_ok == 1 {
                if volatile_read_u8(base + j) == 0 {
                    found = 1
                    let size = volatile_read(base + 64)
                    let data_off = volatile_read(base + 72)
                    let data_base = 0x4700A000 + data_off
                    let mut k = 0
                    while k < size {
                        putc(volatile_read_u8(data_base + k))
                        k = k + 1
                    }
                    if size > 0 {
                        nl()
                    }
                }
            }
        }
        slot = slot + 1
    }
    if found == 0 {
        putc(63) nl()
    }
}

