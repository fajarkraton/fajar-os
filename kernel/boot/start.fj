}

fn execute_cmd() {
    let len = cmd_len()
    if len == 0 {
        putc(0)
    } else {
        let mut handled = 0
        if cmd_is_help() == 1 {
            cmd_help()
            handled = 1
        }
        if cmd_is_ps() == 1 {
            cmd_ps()
            handled = 1
        }
        if cmd_is_uptime() == 1 {
            cmd_uptime()
            handled = 1
        }
        if cmd_is_clear() == 1 {
            cmd_clear_screen()
            handled = 1
        }
        if cmd_is_mem() == 1 {
            cmd_mem()
            handled = 1
        }
        if cmd_is_echo() == 1 {
            cmd_echo()
            handled = 1
        }
        if cmd_is_peek() == 1 {
            cmd_peek()
            handled = 1
        }
        if cmd_is_ticks() == 1 {
            cmd_ticks()
            handled = 1
        }
        if cmd_is_poke() == 1 {
            cmd_poke()
            handled = 1
        }
        if cmd_is_dump() == 1 {
            cmd_dump()
            handled = 1
        }
        if cmd_is_sleep() == 1 {
            cmd_sleep()
            handled = 1
        }
        if cmd_is_version() == 1 {
            cmd_version()
            handled = 1
        }
        if cmd_is_halt() == 1 {
            cmd_halt()
            handled = 1
        }
        if cmd_is_whoami() == 1 {
            cmd_whoami()
            handled = 1
        }
        if cmd_is_date() == 1 {
            cmd_date()
            handled = 1
        }
        if cmd_is_history() == 1 {
            cmd_history()
            handled = 1
        }
        if cmd_is_reg() == 1 {
            cmd_reg()
            handled = 1
        }
        if cmd_is_bench() == 1 {
            cmd_bench()
            handled = 1
        }
        if cmd_is_env() == 1 {
            cmd_env()
            handled = 1
        }
        if cmd_is_export() == 1 {
            cmd_export()
            handled = 1
        }
        if cmd_is_kill() == 1 {
            cmd_kill()
            handled = 1
        }
        if cmd_is_free() == 1 {
            cmd_free()
            handled = 1
        }
        if cmd_is_fill() == 1 {
            cmd_fill()
            handled = 1
        }
        if cmd_is_hex() == 1 {
            cmd_hex()
            handled = 1
        }
        if cmd_is_dmesg() == 1 {
            cmd_dmesg()
            handled = 1
        }
        if cmd_is_cmp() == 1 {
            cmd_cmp()
            handled = 1
        }
        if cmd_is_test() == 1 {
            cmd_test()
            handled = 1
        }
        if cmd_is_top() == 1 {
            cmd_top()
            handled = 1
        }
        if handled == 0 {
            putc(63)
            nl()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════
// Exception handlers (minimal, no scheduler needed for shell)
// ═══════════════════════════════════════════════════════════════════

fn fj_exception_sync(esr: i64, elr: i64, far: i64) {
}

fn fj_exception_irq() {
    let mut irq = 0
    asm!("mrs x0, ICC_IAR1_EL1", out("x0") irq)
    asm!("msr ICC_EOIR1_EL1, x0", in("x0") irq)
}

// ═══════════════════════════════════════════════════════════════════
// Kernel Main — Shell Loop
// ═══════════════════════════════════════════════════════════════════

fn kernel_main() -> i64 {
    // Init dmesg
    volatile_write(0x47007F00, 0)
    // Log: "BOOT"
    dmesg_log(66, 79, 79, 84)
    // Log: "GIC "
    dmesg_log(71, 73, 67, 32)
    // Log: "SHEL"
    dmesg_log(83, 72, 69, 76)

    // Banner
    putc(70)
    putc(97)
    putc(106)
    putc(97)
    putc(114)
    putc(79)
    putc(83)
    putc(32)
    putc(118)
    putc(51)
    putc(46)
    putc(48)
    putc(32)
    putc(83)
    putc(117)
    putc(114)
    putc(121)
    putc(97)
    nl()
    nl()

    // Process table init
    volatile_write(0x47000008, 2)
    volatile_write(0x47001000, 0)

    // Shell loop: read chars, execute on Enter
    prompt()
    cmd_clear()

    let mut running = 1
    while running == 1 {
        if uart_has_char() == 1 {
            let c = uart_getc()
            if c == 13 {
                // Enter
                nl()
                history_add()
                execute_cmd()
                cmd_clear()
                prompt()
            } else {
                if c == 10 {
                    // Also handle LF as Enter
                    nl()
                    history_add()
                    execute_cmd()
                    cmd_clear()
                    prompt()
                } else {
                    if c == 127 {
                        // Backspace
                        let len = cmd_len()
                        if len > 0 {
                            volatile_write(0x47003080, len - 1)
                            putc(8)
                            putc(32)
                            putc(8)
                        }
                    } else {
                        if c >= 32 {
                            cmd_push(c)
                            putc(c)
                        }
                    }
                }
            }
        } else {
            asm!("wfi")
        }
    }

    0
}

fn main() -> i64 { 0 }
