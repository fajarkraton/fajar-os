}

fn cmd_prime() {
    let n = parse_num_from(6)
    if n < 2 {
        println("NO")
    } else {
        let mut is_p = 1
        let mut d = 2
        while d * d <= n {
            if (n / d) * d == n {
                is_p = 0
                d = n
            }
            d = d + 1
        }
        if is_p == 1 {
            println("YES")
        } else {
            println("NO")
        }
    }
}

