fn cmd_pmap() {
    // Show memory map for all active processes
    println("PID  TTBR0        STACK")
    println("---  ----------   -----")
    let mut p = 0
    while p < MAX_PROCS {
        let base = PROC_TABLE_BASE + p * PROC_SLOT_SIZE
        let st = volatile_read(base + 8)
        if st != STATE_FREE {
            if p < 10 { print(" ") }
            print_num(p)
            print("   ")
            let ttbr0 = volatile_read(base + 64)
            print_hex32(ttbr0)
            print("   ")
            let stack = 0x48000000 + (p + 1) * 0x10000
            print_hex32(stack)
            nl()
        }
        p = p + 1
    }
}

fn cmd_is_memstat() -> i64 {
    let len = cmd_len()
    if len != 7 { 0 }
    else { if cmd_char(0) == 109 { if cmd_char(1) == 101 { if cmd_char(5) == 97 { if cmd_char(6) == 116 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_memstat() {
    // Show memory statistics
    let pt_cur = volatile_read(PT_BUMP_ADDR)
    let pt_base = 0x46000000
    let pt_used = (pt_cur - pt_base) / 4096
    print("Page tables: ")
    print_num(pt_used)
    print(" (")
    print_num(pt_used * 4)
    println("KB)")

    // Process count
    let mut active = 0
    let mut p = 0
    while p < MAX_PROCS {
        let st = volatile_read(PROC_TABLE_BASE + p * PROC_SLOT_SIZE + 8)
        if st != STATE_FREE {
            active = active + 1
        }
        p = p + 1
    }
    print("Processes: ")
    print_num(active)
    print("/")
    print_num(MAX_PROCS)
    nl()

    // Stack memory: 64KB per process
    print("Stack: ")
    print_num(active * 64)
    println("KB")

    // Kernel regions
    println("Kernel:  0x40000000-0x47FFFFFF (128MB)")
    println("MMIO:    0x00000000-0x0FFFFFFF (256MB)")
    println("Stacks:  0x48000000-0x48FFFFFF (16MB)")
    println("PT pool: 0x46000000-0x46FFFFFF (16MB)")
}

// Sprint 36.7 preview: bench command
fn cmd_is_bench() -> i64 {
    let len = cmd_len()
    if len != 5 { 0 }
    else { if cmd_char(0) == 98 { if cmd_char(1) == 101 { if cmd_char(4) == 104 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_bench() {
    // CPU: loop 1M iterations, measure time
    print("CPU: ")
    let t0 = timer_ticks()
    let mut i = 0
    while i < 1000000 {
        i = i + 1
    }
    let t1 = timer_ticks()
    let f = timer_freq()
    let us = (t1 - t0) / (f / 1000000)
    print_num(us)
    println("us/1M")

    // MEM: write 4KB, measure
    print("MEM: ")
    let t2 = timer_ticks()
    let mut j = 0
    while j < 4096 {
        volatile_write(0x47005000 + j, j)
        j = j + 8
    }
    let t3 = timer_ticks()
    let mem_us = (t3 - t2) / (f / 1000000)
    print_num(mem_us)
    println("us/4K")
}

// ═══════════════════════════════════════════════════════════════════
// Shell prompt + read + execute
// ═══════════════════════════════════════════════════════════════════

fn prompt() {
    print("[")
    let pid = volatile_read(CUR_PID)
    putc(48 + pid)
    print("] fjsh> ")
}

fn cmd_is_clear() -> i64 {
    let len = cmd_len()
    if len != 5 { 0 }
    else { if cmd_char(0) == 99 { if cmd_char(1) == 108 { if cmd_char(4) == 114 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_is_mem() -> i64 {
    let len = cmd_len()
    if len != 3 { 0 }
    else { if cmd_char(0) == 109 { if cmd_char(1) == 101 { if cmd_char(2) == 109 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_is_echo() -> i64 {
    let len = cmd_len()
    if len < 5 { 0 }
    else { if cmd_char(0) == 101 { if cmd_char(1) == 99 { if cmd_char(2) == 104 { if cmd_char(3) == 111 { if cmd_char(4) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_clear_screen() {
    // Send ESC[2J ESC[H (clear screen + home)
    putc(27)
    putc(91)
    putc(50)
    putc(74)
    putc(27)
    putc(91)
    putc(72)
}

fn cmd_echo() {
    // Print everything after "echo "
    let len = cmd_len()
    let mut i = 5
    while i < len {
        putc(cmd_char(i))
        i = i + 1
    }
    nl()
}

fn cmd_mem() {
    println("Stack: 64KB")
    print("Timer: ")
    let f = timer_freq()
    print_num(f / 1000000)
    println("MHz")
    print("EL: ")
    let mut el = 0
    asm!("mrs x0, CurrentEL", out("x0") el)
    putc(48 + ((el >> 2) & 3))
    nl()
}

fn tab_complete() {
    // Simple tab completion: match first char against known commands
    let len = cmd_len()
    if len == 0 { return }
    let c0 = cmd_char(0)

    // Single-char completions
    if len == 1 {
        if c0 == 104 { // 'h' → help
            print("elp")
            cmd_push(101) cmd_push(108) cmd_push(112)
        }
        if c0 == 112 { // 'p' → ps
            print("s")
            cmd_push(115)
        }
        if c0 == 116 { // 't' → top
            print("op")
            cmd_push(111) cmd_push(112)
        }
        if c0 == 100 { // 'd' → demo
            print("emo")
            cmd_push(101) cmd_push(109) cmd_push(111)
        }
        if c0 == 109 { // 'm' → mem
            print("em")
            cmd_push(101) cmd_push(109)
        }
        if c0 == 117 { // 'u' → uptime
            print("ptime")
            cmd_push(112) cmd_push(116) cmd_push(105) cmd_push(109) cmd_push(101)
        }
    }
    if len == 2 {
        let c1 = cmd_char(1)
        if c0 == 115 {
            if c1 == 112 { // 'sp' → spawn
                print("awn ")
                cmd_push(97) cmd_push(119) cmd_push(110) cmd_push(32)
            }
            if c1 == 121 { // 'sy' → sysinfo
                print("sinfo")
                cmd_push(115) cmd_push(105) cmd_push(110) cmd_push(102) cmd_push(111)
            }
        }
        if c0 == 107 {
            if c1 == 105 { // 'ki' → kill
                print("ll ")
                cmd_push(108) cmd_push(108) cmd_push(32)
            }
        }
    }
}

fn execute_cmd() {
    let len = cmd_len()
    if len == 0 {
        putc(0)
    } else {
        let mut handled = 0
