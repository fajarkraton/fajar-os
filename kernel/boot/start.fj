// FajarOS v3.0 "Surya" — Interactive Shell (fjsh)
//
// Shell reads commands from UART, executes them.
// Commands: help, ps, uptime, echo, reboot
//
// Build: fj build kernel/boot/start.fj --target aarch64-unknown-none --no-std -o fajaros.elf
// Run:   qemu-system-aarch64 -M virt,gic-version=3 -cpu cortex-a76 -m 512M -kernel fajaros.elf -nographic

@panic_handler
fn panic(code: i64) -> i64 { code }

fn putc(c: i64) {
    volatile_write(0x09000000, c)
}

fn nl() {
    putc(10)
}

fn print_num(n: i64) {
    if n > 99 {
        let h = n / 100
        putc(48 + h)
        let r = n - h * 100
        let t = r / 10
        putc(48 + t)
        putc(48 + r - t * 10)
    } else {
        if n > 9 {
            let t = n / 10
            putc(48 + t)
            putc(48 + n - t * 10)
        } else {
            putc(48 + n)
        }
    }
}

// ═══════════════════════════════════════════════════════════════════
// Timer
// ═══════════════════════════════════════════════════════════════════

fn timer_ticks() -> i64 {
    timer_count()
}

// timer_freq() is now a compiler builtin (fj_rt_bare_timer_freq)
// All calls to timer_freq() throughout this file go directly to the builtin.

fn uptime_ms() -> i64 {
    let t = timer_ticks()
    let f = timer_freq()
    if f > 0 {
        t / (f / 1000)
    } else {
        0
    }
}

// ═══════════════════════════════════════════════════════════════════
// UART Input (PL011 read)
// ═══════════════════════════════════════════════════════════════════

fn uart_has_char() -> i64 {
    let fr = volatile_read_u32(0x09000018)
    if (fr & 16) == 0 {
        1
    } else {
        0
    }
}

fn uart_getc() -> i64 {
    volatile_read_u32(0x09000000) & 0xFF
}

// ═══════════════════════════════════════════════════════════════════
// Command buffer (at 0x47003000, max 128 chars)
// ═══════════════════════════════════════════════════════════════════

fn cmd_clear() {
    let mut i = 0
    while i < 128 {
        volatile_write_u8(0x47003000 + i, 0)
        i = i + 1
    }
    volatile_write(0x47003080, 0)
}

fn cmd_len() -> i64 {
    volatile_read(0x47003080)
}

fn cmd_push(c: i64) {
    let pos = cmd_len()
    if pos < 127 {
        volatile_write_u8(0x47003000 + pos, c)
        volatile_write(0x47003080, pos + 1)
    }
}

fn cmd_char(idx: i64) -> i64 {
    volatile_read_u8(0x47003000 + idx)
}

// ═══════════════════════════════════════════════════════════════════
// Command matching (compare buffer against known strings)
// ═══════════════════════════════════════════════════════════════════

fn cmd_is_help() -> i64 {
    let len = cmd_len()
    if len != 4 { 0 }
    else { if cmd_char(0) == 104 { if cmd_char(1) == 101 { if cmd_char(2) == 108 { if cmd_char(3) == 112 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_is_ps() -> i64 {
    let len = cmd_len()
    if len != 2 { 0 }
    else { if cmd_char(0) == 112 { if cmd_char(1) == 115 { 1 } else { 0 } } else { 0 } }
}

fn cmd_is_uptime() -> i64 {
    let len = cmd_len()
    if len != 6 { 0 }
    else { if cmd_char(0) == 117 { if cmd_char(1) == 112 { if cmd_char(5) == 101 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

// ═══════════════════════════════════════════════════════════════════
// Shell Commands
// ═══════════════════════════════════════════════════════════════════

fn help_line(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) {
    putc(32)
    putc(32)
    putc(a)
    putc(b)
    putc(c)
    putc(d)
    putc(e)
    putc(f)
    nl()
}

fn cmd_help() {
    println("Commands:")
    println("  help ps mem echo uptime clear")
    println("  peek poke dump ticks sleep")
    println("  version halt whoami date history")
    println("  reg bench env export kill free")
    println("  fill hex dmesg cmp test top")
    println("  about log colors calc reboot")
    println("  time seq xxd rand loops ascii")
    println("  bits prime swap wc head fib")
    println("  fact gcd pow sysinfo ls touch")
    println("  rm cat stat mkdir cp mount")
    println("  lsfat catfat df sync spawn wait")
    println("  demo ipc")
}

fn cmd_ps() {
    println("PID STATE  TICKS PRI NAME")
    println("--- -----  ----- --- ----")
    let mut p = 0
    while p < MAX_PROCS {
        let base = PROC_TABLE_BASE + p * PROC_SLOT_SIZE
        let st = volatile_read(base + 8)
        if st != STATE_FREE {
            if p < 10 { print(" ") }
            print_num(p)
            print("  ")
            if st == STATE_READY { print("READY") }
            if st == STATE_RUNNING { print("*RUN*") }
            if st == STATE_BLOCKED { print("BLOCK") }
            if st == STATE_TERMINATED { print(" DEAD") }
            // Ticks
            print("  ")
            let ticks = volatile_read(base + 80)
            print_num(ticks)
            // Priority
            print("   ")
            let prio = volatile_read(base + 96)
            print_num(prio)
            // Name
            print("  ")
            let name_ch = volatile_read(base + 88)
            if name_ch > 0 {
                putc(name_ch)
            } else {
                if p == 0 { print("kernel") }
                if p == 15 { print("idle") }
                if p > 0 { if p < 15 { print("-") } }
            }
            nl()
        }
        p = p + 1
    }
}

fn cmd_uptime() {
    let ms = uptime_ms()
    let sec = ms / 1000
    let rem = ms - sec * 1000
    print_num(sec)
    print(".")
    if rem < 100 {
        print("0")
    }
    if rem < 10 {
        print("0")
    }
    print_num(rem)
    println("s")
}

// ═══════════════════════════════════════════════════════════════════
// Number parsing (for peek/poke addresses)
// ═══════════════════════════════════════════════════════════════════

fn parse_hex_digit(c: i64) -> i64 {
    if c >= 48 {
        if c <= 57 {
            c - 48
        } else {
            if c >= 97 {
                if c <= 102 {
                    c - 87
                } else {
                    0
                }
            } else {
                if c >= 65 {
                    if c <= 70 {
                        c - 55
                    } else {
                        0
                    }
                } else {
                    0
                }
            }
        }
    } else {
        0
    }
}

fn is_space(c: i64) -> i64 {
    if c == 32 { 1 } else { 0 }
}

fn parse_num_from(start: i64) -> i64 {
    let len = cmd_len()
    let mut val = 0
    let mut i = start
    if i >= len { 0 }
    else { if cmd_char(i) == 48 {
        if i + 1 < len {
            if cmd_char(i + 1) == 120 {
                // Hex: 0x...
                i = i + 2
                while i < len {
                    let c = cmd_char(i)
                    if is_space(c) == 1 {
                        i = len
                    } else {
                        val = val * 16 + parse_hex_digit(c)
                        i = i + 1
                    }
                }
                val
            } else {
                while i < len {
                    let c = cmd_char(i)
                    if is_space(c) == 1 { i = len }
                    else { if c >= 48 { if c <= 57 { val = val * 10 + c - 48 } } i = i + 1 }
                }
                val
            }
        } else { 0 }
    } else {
        while i < len {
            let c = cmd_char(i)
            if is_space(c) == 1 { i = len }
            else { if c >= 48 { if c <= 57 { val = val * 10 + c - 48 } } i = i + 1 }
        }
        val
    } }
}

fn print_hex_byte(v: i64) {
    let hi = (v >> 4) & 15
    let lo = v & 15
    if hi > 9 { putc(87 + hi) } else { putc(48 + hi) }
    if lo > 9 { putc(87 + lo) } else { putc(48 + lo) }
}

fn print_hex32(v: i64) {
    putc(48)
    putc(120)
    print_hex_byte((v >> 24) & 255)
    print_hex_byte((v >> 16) & 255)
    print_hex_byte((v >> 8) & 255)
    print_hex_byte(v & 255)
}

// ═══════════════════════════════════════════════════════════════════
// New commands: peek, poke, ticks, run, kill
// ═══════════════════════════════════════════════════════════════════

fn cmd_is_peek() -> i64 {
    let len = cmd_len()
    if len < 6 { 0 }
    else { if cmd_char(0) == 112 { if cmd_char(1) == 101 { if cmd_char(2) == 101 { if cmd_char(3) == 107 { if cmd_char(4) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_is_poke() -> i64 {
    let len = cmd_len()
    if len < 6 { 0 }
    else { if cmd_char(0) == 112 { if cmd_char(1) == 111 { if cmd_char(2) == 107 { if cmd_char(3) == 101 { if cmd_char(4) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_is_ticks() -> i64 {
    let len = cmd_len()
    if len != 5 { 0 }
    else { if cmd_char(0) == 116 { if cmd_char(1) == 105 { if cmd_char(4) == 115 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_peek() {
    let addr = parse_num_from(5)
    let val = volatile_read_u32(addr)
    print_hex32(addr)
    putc(58)
    putc(32)
    print_hex32(val)
    nl()
}

// parse_num_at: parse number starting at position, stop at space or end
fn parse_num_at(start: i64) -> i64 {
    // Save original cmd buffer end, temporarily null-terminate at next space
    let len = cmd_len()
    let mut end = start
    while end < len {
        if cmd_char(end) == 32 {
            end = len
        }
        end = end + 1
    }
    parse_num_from(start)
}

// Find second argument position (after first space after pos 5)
fn find_arg2() -> i64 {
    let len = cmd_len()
    let mut i = 5
    // Skip first arg
    while i < len {
        if cmd_char(i) == 32 {
            i = i + 1
            if i < len {
                i
            } else {
                0
            }
        } else {
            i = i + 1
        }
    }
    0
}

fn cmd_poke() {
    // "poke <addr> <value>"
    let addr = parse_num_from(5)
    // Find value after second space
    let len = cmd_len()
    let mut i = 5
    let mut found_space = 0
    let mut val_start = 0
    while i < len {
        if cmd_char(i) == 32 {
            if found_space == 0 {
                found_space = 1
                val_start = i + 1
            }
        }
        i = i + 1
    }
    if found_space == 1 {
        let val = parse_num_from(val_start)
        volatile_write_u32(addr, val)
        print_hex32(addr)
        print(" <- ")
        print_hex32(val)
        nl()
    } else {
        // No value — write 0
        volatile_write_u32(addr, 0)
        print_hex32(addr)
        println(" <- 0")
    }
}

fn cmd_is_dump() -> i64 {
    let len = cmd_len()
    if len < 6 { 0 }
    else { if cmd_char(0) == 100 { if cmd_char(1) == 117 { if cmd_char(2) == 109 { if cmd_char(3) == 112 { if cmd_char(4) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_dump() {
    // "dump <addr>" — show 64 bytes (4 rows of 16)
    let base = parse_num_from(5)
    let mut row = 0
    while row < 4 {
        let addr = base + row * 16
        print_hex32(addr)
        putc(58)
        let mut col = 0
        while col < 16 {
            if (col & 3) == 0 {
                putc(32)
            }
            let b = volatile_read_u8(addr + col)
            print_hex_byte(b)
            col = col + 1
        }
        putc(32)
        putc(124)
        // ASCII representation
        let mut col2 = 0
        while col2 < 16 {
            let b2 = volatile_read_u8(addr + col2)
            if b2 >= 32 {
                if b2 < 127 {
                    putc(b2)
                } else {
                    putc(46)
                }
            } else {
                putc(46)
            }
            col2 = col2 + 1
        }
        putc(124)
        nl()
        row = row + 1
    }
}

fn cmd_is_sleep() -> i64 {
    let len = cmd_len()
    if len < 7 { 0 }
    else { if cmd_char(0) == 115 { if cmd_char(1) == 108 { if cmd_char(2) == 101 { if cmd_char(3) == 101 { if cmd_char(4) == 112 { if cmd_char(5) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_sleep() {
    let ms = parse_num_from(6)
    let t0 = uptime_ms()
    // Busy-wait based sleep (no timer IRQ needed)
    let f = timer_freq()
    let target = timer_ticks() + f / 1000 * ms
    let mut now = timer_ticks()
    while now < target {
        now = timer_ticks()
    }
    let t1 = uptime_ms()
    let elapsed = t1 - t0
    print_num(elapsed)
    println("ms")
}

fn cmd_ticks() {
    let ms = uptime_ms()
    let secs = ms / 1000
    let frac = (ms % 1000) / 100
    print_num(secs)
    putc(46)
    print_num(frac)
    print("s (")
    let irqs = timer_irq_total()
    print_num(irqs)
    println(" IRQs)")
}

