fn cmd_is_xxd() -> i64 {
    let len = cmd_len()
    if len < 5 { 0 }
    else { if cmd_char(0) == 120 { if cmd_char(1) == 120 { if cmd_char(2) == 100 { if cmd_char(3) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_xxd() {
    // "xxd <addr>" — 256-byte hex dump (16 rows)
    let base = parse_num_from(4)
    let mut row = 0
    while row < 16 {
        let addr = base + row * 16
        print_hex32(addr)
        putc(58)
        let mut col = 0
        while col < 16 {
            if (col & 1) == 0 {
                putc(32)
            }
            print_hex_byte(volatile_read_u8(addr + col))
            col = col + 1
        }
        putc(32)
        let mut col2 = 0
        while col2 < 16 {
            let b = volatile_read_u8(addr + col2)
            if b >= 32 {
                if b < 127 {
                    putc(b)
                } else {
                    putc(46)
                }
            } else {
                putc(46)
            }
            col2 = col2 + 1
        }
        nl()
        row = row + 1
    }
}

