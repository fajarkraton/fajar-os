}

fn cmd_is_halt() -> i64 {
    let len = cmd_len()
    if len != 4 { 0 }
    else { if cmd_char(0) == 104 { if cmd_char(1) == 97 { if cmd_char(2) == 108 { if cmd_char(3) == 116 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_halt() {
    println("Halting...")
    asm!("wfi")
}

fn cmd_is_whoami() -> i64 {
    let len = cmd_len()
    if len != 6 { 0 }
    else { if cmd_char(0) == 119 { if cmd_char(1) == 104 { if cmd_char(5) == 105 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_whoami() {
    println("root")
}

fn cmd_is_date() -> i64 {
    let len = cmd_len()
    if len != 4 { 0 }
    else { if cmd_char(0) == 100 { if cmd_char(1) == 97 { if cmd_char(2) == 116 { if cmd_char(3) == 101 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_date() {
    // No RTC, show boot-relative time
    let ms = uptime_ms()
    let total_sec = ms / 1000
    let hours = total_sec / 3600
    let mins = (total_sec - hours * 3600) / 60
    let secs = total_sec - hours * 3600 - mins * 60
    print("Boot+")
    if hours < 10 { print("0") }
    print_num(hours)
    print(":")
    if mins < 10 { print("0") }
    print_num(mins)
    print(":")
    if secs < 10 { print("0") }
    print_num(secs)
    nl()
}

fn cmd_is_history() -> i64 {
    let len = cmd_len()
    if len != 7 { 0 }
    else { if cmd_char(0) == 104 { if cmd_char(1) == 105 { if cmd_char(6) == 121 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

// History buffer: last 8 commands at 0x47004000, 128 bytes each
fn history_add() {
    let count = volatile_read(0x47004800)
    let slot = count & 7
    let base = 0x47004000 + slot * 128
    let len = cmd_len()
    let mut i = 0
    while i < len {
        if i < 127 {
            volatile_write_u8(base + i, cmd_char(i))
        }
        i = i + 1
    }
    volatile_write_u8(base + len, 0)
    volatile_write(0x47004800, count + 1)
}

fn cmd_history() {
    let count = volatile_read(0x47004800)
    let mut i = 0
    let start = if count > 8 { count - 8 } else { 0 }
    while i < 8 {
        if start + i < count {
            let slot = (start + i) & 7
            let base = 0x47004000 + slot * 128
            print_num(start + i + 1)
            putc(32)
            let mut j = 0
            let mut c = volatile_read_u8(base)
            while c != 0 {
                putc(c)
                j = j + 1
                c = volatile_read_u8(base + j)
            }
            nl()
        }
        i = i + 1
    }
}

// ═══════════════════════════════════════════════════════════════════
// Sprint 36.1 continued: env, export
// Env vars stored at 0x47006000 (16 slots × 128 bytes)
// Each slot: [0-63]=key, [64-127]=value
// ═══════════════════════════════════════════════════════════════════

fn env_count() -> i64 {
    volatile_read(0x47006800)
}

fn cmd_is_env() -> i64 {
    let len = cmd_len()
    if len != 3 { 0 }
    else { if cmd_char(0) == 101 { if cmd_char(1) == 110 { if cmd_char(2) == 118 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_env() {
    let count = env_count()
    if count == 0 {
        println("(empty)")
    } else {
        let mut i = 0
        while i < count {
            let base = 0x47006000 + i * 128
            let mut j = 0
            let mut c = volatile_read_u8(base + j)
            while c != 0 {
                putc(c)
                j = j + 1
                c = volatile_read_u8(base + j)
            }
            putc(61)
            j = 0
            c = volatile_read_u8(base + 64 + j)
            while c != 0 {
                putc(c)
                j = j + 1
                c = volatile_read_u8(base + 64 + j)
            }
            nl()
            i = i + 1
        }
    }
}

fn cmd_is_export() -> i64 {
    let len = cmd_len()
    if len < 8 { 0 }
    else { if cmd_char(0) == 101 { if cmd_char(1) == 120 { if cmd_char(5) == 116 { if cmd_char(6) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_export() {
    // "export KEY=VALUE"
    let len = cmd_len()
    let count = env_count()
    if count >= 16 {
        println("full")
    } else {
        let base = 0x47006000 + count * 128
        // Copy key (from pos 7 to '=')
        let mut i = 7
        let mut ki = 0
        while i < len {
            let c = cmd_char(i)
            if c == 61 {
                volatile_write_u8(base + ki, 0)
                i = i + 1
                // Copy value
                let mut vi = 0
                while i < len {
                    volatile_write_u8(base + 64 + vi, cmd_char(i))
                    vi = vi + 1
                    i = i + 1
                }
                volatile_write_u8(base + 64 + vi, 0)
                i = len
            } else {
                volatile_write_u8(base + ki, c)
                ki = ki + 1
                i = i + 1
            }
        }
        volatile_write(0x47006800, count + 1)
    }
}

// ═══════════════════════════════════════════════════════════════════
// Process commands (kill, nice)
// ═══════════════════════════════════════════════════════════════════

fn cmd_is_nice() -> i64 {
    let len = cmd_len()
    if len < 7 { 0 }
    else { if cmd_char(0) == 110 { if cmd_char(1) == 105 { if cmd_char(2) == 99 { if cmd_char(3) == 101 { if cmd_char(4) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_nice() {
    // "nice <prio> <pid>" — set process priority
    // prio: 0=IDLE, 1=NORMAL, 2=HIGH, 3=REALTIME
    let prio = cmd_char(5) - 48
    let pid = cmd_char(7) - 48
    if pid > 0 {
        if pid < 15 {
            if prio >= 0 {
                if prio <= 3 {
                    let base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
                    let st = volatile_read(base + 8)
                    if st != STATE_FREE {
                        volatile_write(base + 96, prio)
                        print("PID ")
                        print_num(pid)
                        print(" prio=")
                        print_num(prio)
                        nl()
                    } else {
                        println("PID not active")
                    }
                } else { println("Prio 0-3") }
            } else { println("Prio 0-3") }
        } else { println("Invalid PID") }
    } else { println("Invalid PID") }
}

fn cmd_is_kill() -> i64 {
    let len = cmd_len()
    if len < 6 { 0 }
    else { if cmd_char(0) == 107 { if cmd_char(1) == 105 { if cmd_char(2) == 108 { if cmd_char(3) == 108 { if cmd_char(4) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_kill() {
    let pid = parse_num_from(5)
    if pid == 0 {
        println("Cannot kill PID 0")
    } else {
        if pid > 14 {
            println("Invalid PID")
        } else {
            let base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
            let st = volatile_read(base + 8)
            if st == STATE_FREE {
                println("PID not active")
            } else {
                if st == 4 {
                    println("Already dead")
                } else {
                    volatile_write(base + 8, 4)  // TERMINATED
                    print("Killed PID ")
                    putc(48 + pid)
                    let name_ch = volatile_read(base + 88)
                    if name_ch > 0 {
                        print(" [")
                        putc(name_ch)
                        print("]")
                    }
                    nl()
                }
            }
        }
    }
}

fn cmd_is_free() -> i64 {
    let len = cmd_len()
    if len != 4 { 0 }
    else { if cmd_char(0) == 102 { if cmd_char(1) == 114 { if cmd_char(2) == 101 { if cmd_char(3) == 101 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_free() {
    // Kernel text
    println("Text: ~8KB")
    // Stack
    println("Stk:  64KB")
    // Process stacks (2 × 64KB)
    println("Proc: 128KB")
    // Page tables
    println("PT:   16MB")
}

fn cmd_is_fill() -> i64 {
    let len = cmd_len()
    if len < 6 { 0 }
    else { if cmd_char(0) == 102 { if cmd_char(1) == 105 { if cmd_char(2) == 108 { if cmd_char(3) == 108 { if cmd_char(4) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_fill() {
    // "fill <addr> <len> <val>"
    let addr = parse_num_from(5)
    // Simple: fill 256 bytes with 0
    let mut i = 0
    while i < 256 {
        volatile_write_u8(addr + i, 0)
        i = i + 1
    }
    putc(50) putc(53) putc(54) putc(32) putc(98) putc(121) putc(116) putc(101) putc(115)
    nl()
}

