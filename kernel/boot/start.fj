// "ipc" — start IPC demo (sender PID 4 → receiver PID 5)
fn cmd_is_ipc() -> i64 {
    let len = cmd_len()
    if len != 3 { 0 }
    else { if cmd_char(0) == 105 { if cmd_char(1) == 112 { if cmd_char(2) == 99 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_ipc() {
    println("IPC demo")

    // Init PID 0
    sched_write_proc(PROC_TABLE_BASE, 0)
    sched_write_proc(PROC_TABLE_BASE + 8, STATE_RUNNING)
    sched_write_proc(CUR_PID, 0)

    // Clear mailbox queues (count=0, head=0, tail=0)
    let mut mb = 0
    while mb < 8 {
        let mba = ipc_mailbox_addr(mb)
        sched_write_proc(mba, 0)
        sched_write_proc(mba + 8, 0)
        sched_write_proc(mba + 16, 0)
        mb = mb + 1
    }

    // Create sender (PID 4) and receiver (PID 5)
    create_process(4, fn_addr(process_sender))
    create_process(5, fn_addr(process_receiver))

    // "4:send 5:recv"
    putc(52) putc(58) putc(115) putc(101) putc(110) putc(100) putc(32)
    putc(53) putc(58) putc(114) putc(101) putc(99) putc(118) nl()
}

// "wait N" — wait for process N to exit
fn cmd_is_wait() -> i64 {
    let len = cmd_len()
    if len != 6 { 0 }
    else { if cmd_char(0) == 119 { if cmd_char(1) == 97 { if cmd_char(2) == 105 { if cmd_char(3) == 116 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_wait() {
    let pid = cmd_char(5) - 48
    if pid > 0 {
        if pid < 15 {
            let base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
            let state = volatile_read(base + 8)
            if state == STATE_TERMINATED {
                print("PID ")
                print_num(pid)
                println(" already exited")
            } else {
                if state == STATE_FREE {
                    println("PID not active")
                } else {
                    print("Waiting for PID ")
                    putc(48 + pid)
                    print("...")
                    let mut done = 0
                    while done == 0 {
                        asm!("wfi")
                        let ts = volatile_read(base + 8)
                        if ts == 4 { done = 1 }
                        if ts == STATE_FREE { done = 1 }
                    }
                    nl()
                    print("PID ")
                    putc(48 + pid)
                    println(" exited")
                }
            }
        }
    }
}

// "spawn X" — spawn process by name (a, b, c, s, r)
fn cmd_is_spawn() -> i64 {
    let len = cmd_len()
    if len != 7 { 0 }
    else { if cmd_char(0) == 115 { if cmd_char(1) == 112 { if cmd_char(2) == 97 { if cmd_char(3) == 119 { if cmd_char(4) == 110 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_spawn() {
    let name_char = cmd_char(6)
    let entry = func_table_lookup(name_char)
    if entry > 0 {
        let pid = find_free_pid()
        if pid > 0 {
            // 'u' = EL0 user process, others = EL1
            if name_char == 117 {
                create_process_el0(pid, entry)
            } else {
                create_process(pid, entry)
            }
            // Store process name in proc table
            let proc_base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
            volatile_write(proc_base + 88, name_char)
            // Reset tick counter
            volatile_write(proc_base + 80, 0)
            // Print result
            print("PID ")
            putc(48 + pid)
            print(" [")
            putc(name_char)
            print("]")
            if name_char == 117 { print(" EL0") }
            nl()
        } else {
            println("No free PID")
        }
    } else {
        print("? ")
        putc(name_char)
        nl()
    }
}

