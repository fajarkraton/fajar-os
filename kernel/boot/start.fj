// Kernel log buffer at 0x47007000 (4KB ring buffer)
fn dmesg_write(c: i64) {
    let pos = volatile_read(0x47007F00)
    if pos < 4000 {
        volatile_write_u8(0x47007000 + pos, c)
        volatile_write(0x47007F00, pos + 1)
    }
}

fn dmesg_log(a: i64, b: i64, c: i64, d: i64) {
    dmesg_write(a)
    dmesg_write(b)
    dmesg_write(c)
    dmesg_write(d)
    dmesg_write(10)
}

fn cmd_is_dmesg() -> i64 {
    let len = cmd_len()
    if len != 5 { 0 }
    else { if cmd_char(0) == 100 { if cmd_char(1) == 109 { if cmd_char(4) == 103 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_dmesg() {
    let pos = volatile_read(0x47007F00)
    let mut i = 0
    while i < pos {
        let c = volatile_read_u8(0x47007000 + i)
        putc(c)
        i = i + 1
    }
    if pos == 0 {
        println("(empty)")
    }
}

