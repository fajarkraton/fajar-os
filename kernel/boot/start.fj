// ═══════════════════════════════════════════════════════════════════
// GICv3 Interrupt Controller (inline for single-file build)
// ═══════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════
// MMU — 2MB Block Mapping (fast identity-map for bare-metal)
// ═══════════════════════════════════════════════════════════════════
//
// Uses L0→L1→L2 with 2MB block entries (no L3 needed).
// 2MB block = 512 pages. 128 blocks = 256MB.
//
// Memory map (identity-mapped):
//   0x00000000-0x0FFFFFFF (256MB) → Device-nGnRnE (MMIO: GIC, UART, VirtIO)
//   0x40000000-0x4FFFFFFF (256MB) → Normal WB (kernel code/data/heap/stacks)
//
// Page table allocation: bump from 0x46000000
// MAIR: idx0=0x00 (Device), idx1=0xFF (Normal WB)
// TCR: T0SZ=16, 4KB granule, inner shareable
//
// Entry format (2MB block at L2):
//   [47:21] = output address (2MB aligned)
//   [1] = 0 (block, not table)
//   [0] = 1 (valid)
//   + AF, SH, AP, AttrIndx flags

const PT_BUMP_ADDR: i64 = 0x4700F100  // bump allocator pointer

fn mmu_pt_alloc() -> i64 {
    let addr = volatile_read(PT_BUMP_ADDR)
    volatile_write(PT_BUMP_ADDR, addr + 4096)
    // Zero 4KB page table
    let mut i = 0
    while i < 4096 {
        volatile_write(addr + i, 0)
        i = i + 8
    }
    addr
}

fn mmu_init() {
    // Init page table bump allocator at 0x46000000
    volatile_write(PT_BUMP_ADDR, 0x46000000)

    // L0 table (512 entries, each covers 512GB)
    let l0 = mmu_pt_alloc()

    // L0[0] → L1 table (covers 0x00-0x7F_FFFF_FFFF, first 512GB)
    // BOTH MMIO (0x00) and kernel (0x40) are within this range
    let l1 = mmu_pt_alloc()
    volatile_write(l0 + 0 * 8, l1 | 3)  // valid + table

    // L1 entries: each covers 1GB
    // L1[0] → L2 for 0x00000000-0x3FFFFFFF (MMIO region)
    let l2_mmio = mmu_pt_alloc()
    volatile_write(l1 + 0 * 8, l2_mmio | 3)  // valid + table

    // L1[1] → L2 for 0x40000000-0x7FFFFFFF (kernel region)
    let l2_kern = mmu_pt_alloc()
    volatile_write(l1 + 1 * 8, l2_kern | 3)  // valid + table

    // Map MMIO: 128 × 2MB blocks (256MB) as Device-nGnRnE
    // Flags: valid(1) | block(0) | AF(1<<10) | SH_inner(3<<8) | AttrIdx0 = 0x701
    let mut i = 0
    while i < 128 {
        let paddr = i * 0x200000
        volatile_write(l2_mmio + i * 8, paddr | 0x701)
        i = i + 1
    }

    // Map kernel: entry 0 = AP=00 (EL1 only), entry 1 = AP=01 (EL0 user code)
    // entries 2-63 = AP=00 (kernel), entries 64-127 = AP=01 (process stacks)
    volatile_write(l2_kern + 0 * 8, 0x40000000 | 0x705)  // kernel code: EL1 only
    volatile_write(l2_kern + 1 * 8, 0x40200000 | 0x745)  // user code: EL0 accessible
    let mut k = 2
    while k < 64 {
        volatile_write(l2_kern + k * 8, (0x40000000 + k * 0x200000) | 0x705)
        k = k + 1
    }
    let mut ku = 64
    while ku < 128 {
        volatile_write(l2_kern + ku * 8, (0x40000000 + ku * 0x200000) | 0x745)
        ku = ku + 1
    }

    // Save kernel L0 address for process page table creation
    volatile_write(0x4700F108, l0)

    // Enable MMU: mmu_enable(mair, tcr, ttbr0)
    mmu_enable(0xFF00, 0x803510, l0)
}

fn gic_init() {
    // GICD: Disable distributor, clear SPIs, set group 1, enable
    let gicd = 0x08000000
    volatile_write_u32(gicd, 0)
    let mut i = 1
    while i < 32 {
        volatile_write_u32(gicd + 0x0180 + i * 4, 0xFFFFFFFF)
        volatile_write_u32(gicd + 0x0280 + i * 4, 0xFFFFFFFF)
        volatile_write_u32(gicd + 0x0080 + i * 4, 0xFFFFFFFF)
        i = i + 1
    }
    volatile_write_u32(gicd, 2)

    // GICR: Wake redistributor, configure SGIs/PPIs
    let gicr = 0x080A0000
    let waker = volatile_read_u32(gicr + 0x0014)
    volatile_write_u32(gicr + 0x0014, waker & 0xFFFFFFFD)
    let mut w = 0
    while w < 1000 {
        let wr = volatile_read_u32(gicr + 0x0014)
        if ((wr >> 2) & 1) == 0 { w = 1000 }
        w = w + 1
    }
    volatile_write_u32(gicr + 0x10080, 0xFFFFFFFF)
    volatile_write_u32(gicr + 0x10180, 0xFFFFFFFF)
    volatile_write_u32(gicr + 0x10280, 0xFFFFFFFF)

    // CPU interface: PMR=0xFF, enable group 1, unmask IRQs
    gic_cpu_init(0xFF)
    irq_enable()
}

fn gic_enable_irq(irq: i64, priority: i64) {
    if irq < 32 {
        let bit = 1 << irq
        volatile_write_u32(0x080A0000 + 0x10100, bit)
        volatile_write_u8(0x080A0000 + 0x10400 + irq, priority)
    } else {
        let reg_idx = irq / 32
        let bit_idx = irq % 32
        volatile_write_u32(0x08000000 + 0x0100 + reg_idx * 4, 1 << bit_idx)
        volatile_write_u8(0x08000000 + 0x0400 + irq, priority)
    }
}

// ═══════════════════════════════════════════════════════════════════
// ARM Generic Timer (CNTP — Physical Timer, PPI 30)
// ═══════════════════════════════════════════════════════════════════

// Timer IRQ count (for uptime and diagnostics)
const TIMER_IRQ_COUNT_ADDR: i64 = 0x4700D000
const TIMER_QUANTUM_TICKS_ADDR: i64 = 0x4700D008

fn timer_init_preempt() {
    // Cache frequency and compute 10ms quantum
    let f = timer_freq()
    let quantum_ticks = f / 100  // 10ms = freq/100
    volatile_write(TIMER_QUANTUM_TICKS_ADDR, quantum_ticks)
    volatile_write(TIMER_IRQ_COUNT_ADDR, 0)

    // Set timer countdown
    timer_set(quantum_ticks)

    // Enable timer (ENABLE=1, IMASK=0) — already done by timer_set()

    // Enable timer PPI (IRQ 30) in GICv3 with high priority
    gic_enable_irq(30, 0x20)
}

fn timer_rearm() {
    let ticks = volatile_read(TIMER_QUANTUM_TICKS_ADDR)
    timer_set(ticks)

    // Increment IRQ count
    let c = volatile_read(TIMER_IRQ_COUNT_ADDR)
    volatile_write(TIMER_IRQ_COUNT_ADDR, c + 1)
}

fn timer_irq_total() -> i64 {
    // Read IRQ flag (set to 1 by IRQ handler via sched_write_proc)
    volatile_read_u32(0x47001020)
}

// ═══════════════════════════════════════════════════════════════════
// Exception Handlers
// ═══════════════════════════════════════════════════════════════════

// Syscall numbers
const SYS_EXIT: i64 = 0
const SYS_WRITE: i64 = 1
const SYS_YIELD: i64 = 2
const SYS_GETPID: i64 = 3
const SYS_IPC_SEND: i64 = 4
const SYS_IPC_RECV: i64 = 5
const SYS_SPAWN: i64 = 6
const SYS_KILL: i64 = 7
const SYS_WAIT: i64 = 8
const SYS_READ: i64 = 9

// ═══════════════════════════════════════════════════════════════════
// Process Function Table (for spawn command)
// ═══════════════════════════════════════════════════════════════════
// Maps single-char names to entry addresses
// Stored at 0x47003000: [char, 0, 0, 0, 0, 0, 0, 0, entry_addr(8 bytes)] × 8 = 128 bytes

const FUNC_TABLE_BASE: i64 = 0x4700E000
const FUNC_TABLE_ENTRY_SIZE: i64 = 16
const FUNC_TABLE_MAX: i64 = 8

fn func_table_init() {
    // Register known process functions using volatile_write (works in main context)
    volatile_write(FUNC_TABLE_BASE + 0, 97)
    volatile_write(FUNC_TABLE_BASE + 8, fn_addr(process_a))
    volatile_write(FUNC_TABLE_BASE + 16, 98)
    volatile_write(FUNC_TABLE_BASE + 24, fn_addr(process_b))
    volatile_write(FUNC_TABLE_BASE + 32, 99)
    volatile_write(FUNC_TABLE_BASE + 40, fn_addr(process_c))
    volatile_write(FUNC_TABLE_BASE + 48, 115)
    volatile_write(FUNC_TABLE_BASE + 56, fn_addr(process_sender))
    volatile_write(FUNC_TABLE_BASE + 64, 114)
    volatile_write(FUNC_TABLE_BASE + 72, fn_addr(process_receiver))
    volatile_write(FUNC_TABLE_BASE + 80, 116)  // 't'
    volatile_write(FUNC_TABLE_BASE + 88, fn_addr(process_t))
    volatile_write(FUNC_TABLE_BASE + 96, 117)  // 'u' = EL0 user process
    volatile_write(FUNC_TABLE_BASE + 104, fn_addr(process_user))
}

fn func_table_lookup(name_char: i64) -> i64 {
    let mut i = 0
    while i < FUNC_TABLE_MAX {
        let addr = FUNC_TABLE_BASE + i * FUNC_TABLE_ENTRY_SIZE
        let ch = volatile_read(addr)
        if ch == name_char {
            return volatile_read(addr + 8)
        }
        i = i + 1
    }
    0
}

// Find a free PID slot (1-14, PID 0=kernel, PID 15=idle)
fn find_free_pid() -> i64 {
    let mut pid = 1
    while pid < 15 {
        let base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
        let state = volatile_read(base + 8)
        if state == STATE_FREE {
            return pid
        }
        if state == STATE_TERMINATED {
            // TERMINATED — recycle
            return pid
        }
        pid = pid + 1
    }
    0
}

// ═══════════════════════════════════════════════════════════════════
// IPC Mailbox System
// ═══════════════════════════════════════════════════════════════════
// Each process has a mailbox at 0x47002000 + pid * 64
// Mailbox: 4-message circular queue per process (128 bytes each)
//   [0]   count (0-4)
//   [8]   head (read index)
//   [16]  tail (write index)
//   [32+i*16] msg[i]: sender(8) + value(8), i=0..3

const IPC_MAILBOX_BASE: i64 = 0x47002000
const IPC_MAILBOX_SIZE: i64 = 128
const IPC_QUEUE_CAP: i64 = 4

fn ipc_mailbox_addr(pid: i64) -> i64 {
    IPC_MAILBOX_BASE + pid * IPC_MAILBOX_SIZE
}

fn ipc_send(dest_pid: i64, value: i64) -> i64 {
    if dest_pid < 0 { 0 }
    else {
        if dest_pid > 7 { 0 }
        else {
            let mbox = ipc_mailbox_addr(dest_pid)
            let count = sched_read_proc(mbox)
            if count >= IPC_QUEUE_CAP { 0 }
            else {
                let tail = sched_read_proc(mbox + 16)
                let sender = sched_read_proc(CUR_PID)
                let msg_addr = mbox + 32 + tail * 16
                sched_write_proc(msg_addr, sender)
                sched_write_proc(msg_addr + 8, value)
                // Advance tail
                let mut new_tail = tail + 1
                if new_tail >= IPC_QUEUE_CAP { new_tail = 0 }
                sched_write_proc(mbox + 16, new_tail)
                sched_write_proc(mbox, count + 1)
                // Wake if BLOCKED
                let dest_base = PROC_TABLE_BASE + dest_pid * PROC_SLOT_SIZE
                let dest_state = sched_read_proc(dest_base + 8)
                if dest_state == 3 {
                    sched_write_proc(dest_base + 8, STATE_READY)
                }
                0
            }
        }
    }
}

fn ipc_recv() -> i64 {
    let my_pid = sched_read_proc(CUR_PID)
    let mbox = ipc_mailbox_addr(my_pid)
    let count = sched_read_proc(mbox)
    if count > 0 {
        let head = sched_read_proc(mbox + 8)
        let msg_addr = mbox + 32 + head * 16
        let value = sched_read_proc(msg_addr + 8)
        let mut new_head = head + 1
        if new_head >= IPC_QUEUE_CAP { new_head = 0 }
        sched_write_proc(mbox + 8, new_head)
        sched_write_proc(mbox, count - 1)
        value
    } else {
        // Block and yield
        let my_base = PROC_TABLE_BASE + my_pid * PROC_SLOT_SIZE
        sched_write_proc(my_base + 8, 3)
        sched_switch()
        // Woken — try read
        let count2 = sched_read_proc(mbox)
        if count2 > 0 {
            let head2 = sched_read_proc(mbox + 8)
            let msg_addr2 = mbox + 32 + head2 * 16
            let value2 = sched_read_proc(msg_addr2 + 8)
            let mut new_head2 = head2 + 1
            if new_head2 >= IPC_QUEUE_CAP { new_head2 = 0 }
            sched_write_proc(mbox + 8, new_head2)
            sched_write_proc(mbox, count2 - 1)
            value2
        } else {
            0
        }
    }
}

fn fj_exception_sync(esr: i64, elr: i64, far: i64) {
    // ESR.EC (bits 31:26) = 0x15 → SVC from AArch64
    let ec = (esr >> 26) & 0x3F
    if ec == 0x15 {
        // SVC syscall — advance ELR by writing directly to ELR_EL1
        // (bypasses sched_write_proc which corrupts the exception frame)
        asm!("mrs x0, ELR_EL1")
        asm!("add x0, x0, #4")
        asm!("msr ELR_EL1, x0")

        // Syscall number in saved x0, args in saved x1, x2
        let syscall_num = syscall_arg0()
        let arg1 = syscall_arg1()
        let arg2 = syscall_arg2()

        if syscall_num == SYS_EXIT {
            let pid = sched_read_proc(CUR_PID)
            let base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
            sched_write_proc(base + 8, 4)  // TERMINATED
            sched_switch()
        }

        if syscall_num == SYS_WRITE {
            // Write arg1 bytes: arg1 = character to print (simplified)
            putc(arg1)
        }

        if syscall_num == SYS_YIELD {
            // Voluntary yield
            sched_switch()
        }

        if syscall_num == SYS_GETPID {
            // Return current PID
            let pid = sched_read_proc(CUR_PID)
            syscall_set_return(pid)
        }

        if syscall_num == SYS_IPC_SEND {
            // ipc_send(dest_pid=arg1, value=arg2)
            let result = ipc_send(arg1, arg2)
            syscall_set_return(result)
        }

        if syscall_num == SYS_IPC_RECV {
            let value = ipc_recv()
            syscall_set_return(value)
        }

        if syscall_num == SYS_SPAWN {
            // arg1 = entry address
            let pid = find_free_pid()
            if pid > 0 {
                create_process(pid, arg1)
                syscall_set_return(pid)
            } else {
                syscall_set_return(0)
            }
        }

        if syscall_num == SYS_KILL {
            // arg1 = target PID
            if arg1 > 0 {
                if arg1 < 15 {
                    let base = PROC_TABLE_BASE + arg1 * PROC_SLOT_SIZE
                    sched_write_proc(base + 8, STATE_TERMINATED)
                    syscall_set_return(0)
                } else {
                    syscall_set_return(-1)
                }
            } else {
                syscall_set_return(-1)
            }
        }

        if syscall_num == SYS_WAIT {
            // arg1 = target PID to wait for
            // Store wait target at proc_table[cur]+56, mark BLOCKED, yield
            let cur_pid = sched_read_proc(CUR_PID)
            let cur_base = PROC_TABLE_BASE + cur_pid * PROC_SLOT_SIZE
            sched_write_proc(cur_base + 56, arg1)  // wait_target_pid
            sched_write_proc(cur_base + 8, 3)      // BLOCKED
            sched_switch()
        }

        if syscall_num == SYS_READ {
            // Non-blocking read from UART
            let fr = volatile_read_u32(0x09000018)
            if (fr & 16) == 0 {
                let ch = volatile_read_u32(0x09000000) & 0xFF
                syscall_set_return(ch)
            } else {
                syscall_set_return(0)
            }
        }
    }

    // Data Abort from lower EL (EL0 page fault)
    if ec == 0x24 {
        let pid = sched_read_proc(CUR_PID)
        print("[FAULT] PID ")
        print_num(pid)
        print(" data abort at 0x")
        print_hex32(far)
        print(" PC=0x")
        print_hex32(elr)
        println(" — killed")
        // Kill the faulting process
        let base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
        sched_write_proc(base + 8, STATE_TERMINATED)
        sched_switch()
    }

    // Data Abort from same EL (kernel page fault — serious!)
    if ec == 0x25 {
        print("[PANIC] kernel data abort at 0x")
        print_hex32(far)
        print(" PC=0x")
        print_hex32(elr)
        nl()
        // Halt — kernel page fault is unrecoverable
        asm!("wfi")
    }

    // Instruction Abort from lower EL (EL0 exec fault)
    if ec == 0x20 {
        let pid = sched_read_proc(CUR_PID)
        print("[FAULT] PID ")
        print_num(pid)
        print(" instruction abort at 0x")
        print_hex32(far)
        println(" — killed")
        let base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
        sched_write_proc(base + 8, STATE_TERMINATED)
        sched_switch()
    }

    // Instruction Abort from same EL (kernel exec fault)
    if ec == 0x21 {
        print("[PANIC] kernel exec fault at 0x")
        print_hex32(far)
        nl()
        asm!("wfi")
    }
}

// Context switch flag address (checked by vector stub after handler returns)
const CTX_SWITCH_SP: i64 = 0x47001010
// Saved SP from vector stub
const SAVED_SP_ADDR: i64 = 0x47001018
// Timer IRQ counter (write via volatile to simple address)
const IRQ_COUNT_ADDR: i64 = 0x47001020

// ═══════════════════════════════════════════════════════════════════
// Process Entry Points (for context switch demo)
// ═══════════════════════════════════════════════════════════════════

// Process A: prints "A" 200 times then exits
fn process_a() -> i64 {
    let mut i = 0
    while i < 200 {
        putc(65)
        let mut j = 0
        while j < 30000 {
            j = j + 1
        }
        i = i + 1
    }
    // Mark self as TERMINATED
    let my_pid = sched_read_proc(CUR_PID)
    let my_base = PROC_TABLE_BASE + my_pid * PROC_SLOT_SIZE
    sched_write_proc(my_base + 8, 4)
    // Yield — scheduler will pick another process
    asm!("wfi")
    0
}

// Process B: prints "B" 200 times then exits
fn process_b() -> i64 {
    let mut i = 0
    while i < 200 {
        putc(66)
        let mut j = 0
        while j < 30000 {
            j = j + 1
        }
        i = i + 1
    }
    let my_pid = sched_read_proc(CUR_PID)
    let my_base = PROC_TABLE_BASE + my_pid * PROC_SLOT_SIZE
    sched_write_proc(my_base + 8, 4)
    asm!("wfi")
    0
}

// Process T: use putc for output, svc only for exit
fn process_t() -> i64 {
    print("TEST!")
    // Exit via SVC
    svc(0, 0, 0)   // SYS_EXIT
    0
}

// Process C: uses syscalls for I/O and exit
fn process_c() -> i64 {
    let mut i = 0
    while i < 100 {
        svc(1, 67, 0)  // SYS_WRITE 'C'
        let mut j = 0
        while j < 30000 {
            j = j + 1
        }
        i = i + 1
    }
    svc(0, 0, 0)  // SYS_EXIT
    0
}

// Process D: IPC sender — sends messages to PID 5
fn process_sender() -> i64 {
    let mut i = 0
    while i < 10 {
        // Send character 'S' (83) + i to PID 5
        // Send to PID 1 (receiver). Convention: spawn r first (PID 1), then s (PID 2)
        svc(4, 1, 83 + i)  // SYS_IPC_SEND(4), dest=1, value='S'+i
        // Print 's' to show we sent
        svc(1, 115, 0)     // SYS_WRITE, char='s'
        let mut j = 0
        while j < 50000 { j = j + 1 }
        i = i + 1
    }
    svc(0, 0, 0)  // SYS_EXIT
    0
}

// Process E: IPC receiver — receives and prints message values
fn process_receiver() -> i64 {
    let mut i = 0
    while i < 10 {
        let msg = svc(5, 0, 0)  // SYS_IPC_RECV (blocks if empty)
        // Print the received character value
        svc(1, msg, 0)          // SYS_WRITE the received value
        i = i + 1
    }
    svc(0, 0, 0)
    0
}

// Create EL0 process (user space, unprivileged)
fn create_process_el0(pid: i64, entry: i64) {
    // Copy user code to EL0-accessible 2MB block (0x40200000, AP=01)
    let user_code = 0x40200000 + pid * 4096
    let mut ci = 0
    while ci < 512 {
        volatile_write(user_code + ci, volatile_read(entry + ci))
        ci = ci + 8
    }
    // I-cache coherence
    asm!("dsb sy")
    asm!("isb")

    // Create process with COPIED code address (in EL0-accessible region)
    create_process(pid, user_code)

    // Override SPSR: M[3:0]=0000 (EL0t)
    let stack_top = 0x48000000 + (pid + 1) * 0x10000 - 16
    let frame_sp = stack_top - 272
    sched_write_proc(frame_sp + 256, 0)

    // Set SP_EL0 for user stack
    let user_sp = 0x48000000 + (pid + 1) * 0x10000 - 0x8000
    asm!("msr SP_EL0, x0", in("x0") user_sp)
}

// Idle process (PID 15): runs when no other process is READY
fn process_idle() -> i64 {
    'idle: loop {
        asm!("wfi")
    }
    0
}

// Process U: runs at EL0, uses SVC for everything
fn process_user() -> i64 {
    svc(1, 85, 0)   // SYS_WRITE 'U'
    svc(1, 83, 0)   // SYS_WRITE 'S'
    svc(1, 69, 0)   // SYS_WRITE 'E'
    svc(1, 82, 0)   // SYS_WRITE 'R'
    svc(1, 33, 0)   // SYS_WRITE '!'
    svc(0, 0, 0)    // SYS_EXIT
    0
}

// Process table constants
const PROC_TABLE_BASE: i64 = 0x47000000
const PROC_SLOT_SIZE: i64 = 256
const MAX_PROCS: i64 = 16
const STATE_FREE: i64 = 0
const STATE_READY: i64 = 1
const STATE_RUNNING: i64 = 2
const STATE_BLOCKED: i64 = 3
const STATE_TERMINATED: i64 = 4
const CUR_PID: i64 = 0x47001000
// Process table layout per slot (256 bytes):
//   [0]  = PID
//   [8]  = State (FREE/READY/RUNNING/BLOCKED/TERMINATED)
//   [16] = SP (saved stack pointer)
//   [24] = PC (entry point, for display)
//   [56] = wait_target (PID being waited on)
//   [64] = TTBR0 (page table base)
//   [80] = ticks (timer IRQ count)
//   [88] = name_char (process name, single char)
//   [96] = priority (0=IDLE, 1=NORMAL, 2=HIGH, 3=REALTIME)
const PRIO_IDLE: i64 = 0
const PRIO_NORMAL: i64 = 1
const PRIO_HIGH: i64 = 2
const PRIO_REALTIME: i64 = 3

// Create per-process page table with shared kernel mapping + unique stack
fn create_proc_page_table(pid: i64) -> i64 {
    // Allocate new L0 page table
    let l0 = mmu_pt_alloc()

    // Read kernel's L0 entry 0 (points to L1 with MMIO + kernel)
    let kernel_l0 = volatile_read(0x4700F108)
    let kernel_l0_entry0 = volatile_read(kernel_l0)

    // Share kernel's L1 table (MMIO + kernel code/data)
    // L0[0] points to same L1 as kernel — shared mapping
    volatile_write(l0, kernel_l0_entry0)

    // Per-process stack is already identity-mapped in kernel L2
    // at 0x48000000 + pid * 0x10000 (within the 0x40000000-0x4FFFFFFF range)
    // No extra mapping needed since kernel L2 covers this region

    l0
}

// Create a process: set up stack frame for context switch
fn create_process(pid: i64, entry: i64) {
    // Process table entry
    let base = PROC_TABLE_BASE + pid * PROC_SLOT_SIZE
    sched_write_proc(base, pid)           // [0] = PID
    sched_write_proc(base + 8, STATE_READY) // [8] = State

    // Stack: 0x48000000 + pid * 0x10000, 64KB each, grows down
    let stack_top = 0x48000000 + (pid + 1) * 0x10000 - 16

    // Set up initial context frame (256 bytes)
    // Zero all register slots
    // Context frame is 272 bytes (matches SAVE_CONTEXT/RESTORE_CONTEXT)
    let frame_sp = stack_top - 272
    let mut off = 0
    while off < 272 {
        sched_write_proc(frame_sp + off, 0)
        off = off + 8
    }
    // [frame_sp + 240] = x30 (link register) = 0
    sched_write_proc(frame_sp + 240, 0)
    // [frame_sp + 248] = ELR_EL1 = entry point
    sched_write_proc(frame_sp + 248, entry)
    // [frame_sp + 256] = SPSR_EL1
    // For EL1 processes: M[3:0]=0101 (EL1h), DAIF=0
    // For EL0 processes: M[3:0]=0000 (EL0t), DAIF=0
    sched_write_proc(frame_sp + 256, 5)  // default: EL1

    // Save initial SP in process table
    sched_write_proc(base + 16, frame_sp) // [16] = SP
    sched_write_proc(base + 24, entry)    // [24] = PC (for display)

    // Create per-process page table (or share kernel's for PID 0/15)
    if pid == 0 {
        let kernel_l0 = volatile_read(0x4700F108)
        sched_write_proc(base + 64, kernel_l0)
    } else {
        if pid == 15 {
            let kernel_l0 = volatile_read(0x4700F108)
            sched_write_proc(base + 64, kernel_l0)
        } else {
            let proc_l0 = create_proc_page_table(pid)
            sched_write_proc(base + 64, proc_l0)
        }
    }

    // Default priority: NORMAL
    sched_write_proc(base + 96, PRIO_NORMAL)   // [96] = priority
}

// Priority-aware round-robin scheduler (16 PIDs)
// Higher priority processes are preferred; same priority = round-robin.
fn sched_switch() {
    let cur = sched_read_proc(CUR_PID)
    let saved_sp = sched_get_saved_sp()

    if saved_sp > 0 {
        // Save current process SP
        let cur_base = PROC_TABLE_BASE + cur * PROC_SLOT_SIZE
        sched_write_proc(cur_base + 16, saved_sp)

        // Mark current as READY (if still RUNNING)
        let cur_state = sched_read_proc(cur_base + 8)
        if cur_state == STATE_RUNNING {
            sched_write_proc(cur_base + 8, STATE_READY)
        }

        // Find next READY process: highest priority first, then round-robin
        let mut best_pid = -1
        let mut best_prio = -1
        let mut checked = 0
        let mut candidate = cur + 1
        while checked < MAX_PROCS {
            if candidate >= MAX_PROCS { candidate = 0 }
            let cand_base = PROC_TABLE_BASE + candidate * PROC_SLOT_SIZE
            let cand_state = sched_read_proc(cand_base + 8)
            if cand_state == STATE_READY {
                let cand_prio = sched_read_proc(cand_base + 96)
                if cand_prio > best_prio {
                    best_prio = cand_prio
                    best_pid = candidate
                }
            }
            candidate = candidate + 1
            checked = checked + 1
        }

        // If found a READY process, switch to it
        if best_pid >= 0 {
            let next_base = PROC_TABLE_BASE + best_pid * PROC_SLOT_SIZE
            sched_write_proc(next_base + 8, STATE_RUNNING)
            sched_write_proc(CUR_PID, best_pid)
            let next_sp = sched_read_proc(next_base + 16)
            sched_set_next_sp(next_sp)

            // TTBR0 switch: load next process's page table
            let next_ttbr0 = sched_read_proc(next_base + 64)
            if next_ttbr0 > 0 {
                switch_ttbr0(next_ttbr0)
            }
        }
    }
}

fn fj_exception_irq() {
    let irq = gic_ack()

    if irq == 30 {
        timer_set(625000)
        // Increment global IRQ counter
        let count = sched_read_proc(0x47001020)
        sched_write_proc(0x47001020, count + 1)

        // Increment per-process tick counter for current process
        let cur_pid = sched_read_proc(CUR_PID)
        let tick_addr = PROC_TABLE_BASE + cur_pid * PROC_SLOT_SIZE + 80
        let cur_ticks = sched_read_proc(tick_addr)
        sched_write_proc(tick_addr, cur_ticks + 1)

        // Check wait-wake: if any BLOCKED process waits for a TERMINATED one, wake it
        let mut wp = 0
        while wp < MAX_PROCS {
            let wb = PROC_TABLE_BASE + wp * PROC_SLOT_SIZE
            let ws = sched_read_proc(wb + 8)
            if ws == 3 {
                // BLOCKED — check what it's waiting for
                let wait_target = sched_read_proc(wb + 56)
                if wait_target > 0 {
                    let tb = PROC_TABLE_BASE + wait_target * PROC_SLOT_SIZE
                    let ts = sched_read_proc(tb + 8)
                    if ts == 4 {
                        // Target is TERMINATED → wake waiter
                        sched_write_proc(wb + 8, STATE_READY)
                        sched_write_proc(wb + 56, 0)
                    }
                }
            }
            wp = wp + 1
        }

        // Run scheduler for context switch
        sched_switch()
    }

    // EOI
    gic_eoi(irq)
}

// ═══════════════════════════════════════════════════════════════════
// Kernel Main — Shell Loop
// ═══════════════════════════════════════════════════════════════════

fn kernel_main() -> i64 {
    // Init RAM filesystem
    fs_init()

    // Init MMU (identity-map MMIO + kernel, enable caches)
    mmu_init()

    // Init dmesg
    volatile_write(0x47007F00, 0)
    // Log: "BOOT"
    dmesg_log(66, 79, 79, 84)
    // Log: "MMU "
    dmesg_log(77, 77, 85, 32)

    // Init GICv3 interrupt controller
    gic_init()
    // Log: "GIC "
    dmesg_log(71, 73, 67, 32)

    // Init IRQ counter + context switch flag
    volatile_write(IRQ_COUNT_ADDR, 0)
    volatile_write(CTX_SWITCH_SP, 0)
    volatile_write(SAVED_SP_ADDR, 0)

    // Init IPC mailbox queues (all zeroed)
    let mut mb_init = 0
    while mb_init < MAX_PROCS {
        let mba = ipc_mailbox_addr(mb_init)
        volatile_write(mba, 0)
        volatile_write(mba + 8, 0)
        volatile_write(mba + 16, 0)
        mb_init = mb_init + 1
    }

    // Init process function table (for spawn command)
    func_table_init()

    // Init preemptive timer (10ms quantum, IRQ 30)
    timer_init_preempt()
    // Log: "TIMR"
    dmesg_log(84, 73, 77, 82)

    // Log: "SHEL"
    dmesg_log(83, 72, 69, 76)

    // Banner
    println("FajarOS v3.0 Surya")
    println("")

    // Process table init: PID 0 = kernel (RUNNING, NORMAL priority)
    // Shell runs at NORMAL so it shares CPU fairly with user processes
    sched_write_proc(PROC_TABLE_BASE, 0)
    sched_write_proc(PROC_TABLE_BASE + 8, STATE_RUNNING)
    sched_write_proc(PROC_TABLE_BASE + 96, PRIO_NORMAL)
    sched_write_proc(CUR_PID, 0)
    // Store kernel TTBR0 for PID 0
    let kernel_l0 = volatile_read(0x4700F108)
    sched_write_proc(PROC_TABLE_BASE + 64, kernel_l0)

    // PID 15 = idle process (IDLE priority, always ready)
    create_process(15, fn_addr(process_idle))
    sched_write_proc(PROC_TABLE_BASE + 15 * PROC_SLOT_SIZE + 96, PRIO_IDLE)

    // Shell loop: read chars, execute on Enter
    prompt()
    cmd_clear()

    let mut running = 1
    while running == 1 {
        if uart_has_char() == 1 {
            let c = uart_getc()
            if c == 13 {
                // Enter
                nl()
                history_add()
                execute_cmd()
                cmd_clear()
                prompt()
            } else {
                if c == 10 {
                    // Also handle LF as Enter
                    nl()
                    history_add()
                    execute_cmd()
                    cmd_clear()
                    prompt()
                } else {
                    if c == 9 {
                        // Tab — autocomplete
                        tab_complete()
                    } else {
                    if c == 3 {
                        // Ctrl+C — cancel current input
                        print("^C")
                        nl()
                        cmd_clear()
                        prompt()
                    } else {
                    if c == 127 {
                        // Backspace (DEL key)
                        let len = cmd_len()
                        if len > 0 {
                            volatile_write(0x47003080, len - 1)
                            putc(8)
                            putc(32)
                            putc(8)
                        }
                    } else {
                    if c == 8 {
                        // Backspace (BS key)
                        let len = cmd_len()
                        if len > 0 {
                            volatile_write(0x47003080, len - 1)
                            putc(8)
                            putc(32)
                            putc(8)
                        }
                    } else {
                    if c == 27 {
                        // ESC sequence — check for arrow keys
                        // Arrow keys: ESC [ A/B/C/D
                        if uart_has_char() == 1 {
                            let c2 = uart_getc()
                            if c2 == 91 {
                                if uart_has_char() == 1 {
                                    let c3 = uart_getc()
                                    if c3 == 65 {
                                        // Up arrow — recall previous command
                                        let count = volatile_read(0x47004800)
                                        if count > 0 {
                                            // Clear current line
                                            let cur_len = cmd_len()
                                            let mut cl = 0
                                            while cl < cur_len {
                                                putc(8) putc(32) putc(8)
                                                cl = cl + 1
                                            }
                                            // Load last command
                                            let slot = (count - 1) & 7
                                            let hbase = 0x47004000 + slot * 128
                                            cmd_clear()
                                            let mut hi = 0
                                            let mut hc = volatile_read_u8(hbase)
                                            while hc != 0 {
                                                cmd_push(hc)
                                                putc(hc)
                                                hi = hi + 1
                                                hc = volatile_read_u8(hbase + hi)
                                            }
                                        }
                                    }
                                    // Down arrow (c3==66), Left (67), Right (68) — ignore for now
                                }
                            }
                        }
                    } else {
                        if c >= 32 {
                            cmd_push(c)
                            putc(c)
                        }
                    }
                    }
                    }
                    }
                    }
                }
            }
        } else {
            asm!("wfi")
        }
    }

    0
}

fn main() -> i64 { 0 }
