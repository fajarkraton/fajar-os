fn cmd_time() {
    // "time <cmd>" — measure execution time of another command
    // Just measure sleep for now
    let ms = parse_num_from(5)
    let t0 = timer_ticks()
    let f = timer_freq()
    let target = t0 + f / 1000 * ms
    let mut now = t0
    while now < target {
        now = timer_ticks()
    }
    let elapsed_us = (now - t0) / (f / 1000000)
    print_num(elapsed_us)
    putc(117)
    putc(115)
    nl()
}

