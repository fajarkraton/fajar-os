    let len = cmd_len()
    if len != 4 { 0 }
    else { if cmd_char(0) == 114 { if cmd_char(1) == 97 { if cmd_char(2) == 110 { if cmd_char(3) == 100 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
