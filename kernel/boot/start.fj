    let len = cmd_len()
    if len < 5 { 0 }
    else { if cmd_char(0) == 103 { if cmd_char(1) == 99 { if cmd_char(2) == 100 { if cmd_char(3) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_gcd() {
    // "gcd <a> <b>" — Euclidean algorithm
    let mut a = parse_num_from(4)
    // Find second number after space
    let len = cmd_len()
    let mut i = 4
    let mut b_start = 0
    while i < len {
        if cmd_char(i) == 32 {
            b_start = i + 1
            i = len
        }
        i = i + 1
    }
    let mut b = parse_num_from(b_start)
    while b > 0 {
        let tmp = b
        b = a - (a / b) * b
        a = tmp
    }
    print_num(a)
    nl()
}

fn cmd_is_pow() -> i64 {
    let len = cmd_len()
    if len < 5 { 0 }
    else { if cmd_char(0) == 112 { if cmd_char(1) == 111 { if cmd_char(2) == 119 { if cmd_char(3) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_pow() {
    // "pow <base> <exp>"
    let base = parse_num_from(4)
    let len = cmd_len()
    let mut i = 4
    let mut e_start = 0
    while i < len {
        if cmd_char(i) == 32 {
            e_start = i + 1
            i = len
        }
        i = i + 1
    }
    let exp = parse_num_from(e_start)
    let mut result = 1
    let mut j = 0
    while j < exp {
        result = result * base
        j = j + 1
    }
    print_num(result)
    nl()
}

fn cmd_is_sysinfo() -> i64 {
    let len = cmd_len()
    if len != 7 { 0 }
    else { if cmd_char(0) == 115 { if cmd_char(1) == 121 { if cmd_char(6) == 111 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_sysinfo() {
    println("FajarOS v3.0")

    // EL
    let mut el = 0
    asm!("mrs x0, CurrentEL", out("x0") el)
    print("EL:")
    putc(48 + ((el >> 2) & 3))
    putc(32)

    // Timer
    let f = timer_freq()
    print_num(f / 1000000)
    print("MHz ")

    // Uptime
    let ms = uptime_ms()
    print_num(ms)
    println("ms")

    // Processes
    let mut running = 0
    let mut ready = 0
    let mut p = 0
    while p < 3 {
        let st = volatile_read(0x47000000 + p * 256 + 8)
        if st == 2 { running = running + 1 }
        if st == 1 { ready = ready + 1 }
        p = p + 1
    }
    print("P:")
    print_num(running)
    print("R ")
    print_num(ready)
    print("W ")

    // Commands
    let cmds = volatile_read(0x47004800)
    print_num(cmds)
    print("C ")

    // Env
    let envs = volatile_read(0x47006800)
    print_num(envs)
    println("E")
}

// ═══════════════════════════════════════════════════════════════════
// RAM Filesystem (Sprint 36.5)
// File table: 0x47008000 (16 files × 128 bytes)
//   [0-62]  = filename (null-terminated)
//   [63]    = type: 0=free, 1=file, 2=dir
//   [64-71] = size (i64)
//   [72-79] = data offset in data area
// Data area: 0x4700A000 (16 × 256 = 4KB)
// ═══════════════════════════════════════════════════════════════════

fn fs_init() {
    let mut i = 0
    while i < 2048 {
        volatile_write_u8(0x47008000 + i, 0)
        i = i + 1
    }
    // Create "/" root dir
    volatile_write_u8(0x47008000, 47)
    volatile_write_u8(0x47008001, 0)
    volatile_write_u8(0x47008063, 2)
}

fn fs_find(name_start: i64) -> i64 {
    let len = cmd_len()
    let mut slot = 0
    while slot < 16 {
        let base = 0x47008000 + slot * 128
        let ftype = volatile_read_u8(base + 63)
        if ftype > 0 {
            let mut match_ok = 1
            let mut j = 0
            let mut ni = name_start
            while ni < len {
                let fc = volatile_read_u8(base + j)
                let nc = cmd_char(ni)
                if fc != nc {
                    match_ok = 0
                    ni = len
                }
                j = j + 1
                ni = ni + 1
            }
            if match_ok == 1 {
                let fc2 = volatile_read_u8(base + j)
                if fc2 == 0 {
                    slot + 100
                } else {
                    match_ok = 0
                }
            }
        }
        slot = slot + 1
    }
    0
}

fn fs_free_slot() -> i64 {
    let mut slot = 0
    while slot < 16 {
        let ftype = volatile_read_u8(0x47008000 + slot * 128 + 63)
        if ftype == 0 {
            slot + 100
        }
        slot = slot + 1
    }
    0
}

// ═══════════════════════════════════════════════════════════════════
// FAT Filesystem on RAM disk (Milestone 1)
// Disk loaded at 0x44000000 by QEMU -device loader
// ═══════════════════════════════════════════════════════════════════

fn fat_read_u16(addr: i64) -> i64 {
    let lo = volatile_read_u8(addr)
    let hi = volatile_read_u8(addr + 1)
    lo + hi * 256
}

fn fat_read_u32(addr: i64) -> i64 {
    volatile_read_u8(addr) + volatile_read_u8(addr + 1) * 256 + volatile_read_u8(addr + 2) * 65536 + volatile_read_u8(addr + 3) * 16777216
}

fn fat_init_disk() {
    let base = 0x44000000
    // Check for valid FAT BPB (bytes per sector should be 512)
    let bps = fat_read_u16(base + 11)
    if bps == 512 {
        volatile_write(0x4700C000, base)
        volatile_write(0x4700C008, bps)
        volatile_write(0x4700C010, volatile_read_u8(base + 13))
        let reserved = fat_read_u16(base + 14)
        volatile_write(0x4700C018, reserved)
        let nfats = volatile_read_u8(base + 16)
        volatile_write(0x4700C020, nfats)
        let root_entries = fat_read_u16(base + 17)
        volatile_write(0x4700C028, root_entries)
        let spf = fat_read_u16(base + 22)
        volatile_write(0x4700C030, spf)
        let root_start = (reserved + nfats * spf) * bps
        volatile_write(0x4700C038, root_start)
        let data_start = root_start + root_entries * 32
        volatile_write(0x4700C040, data_start)
        volatile_write(0x4700C048, 1)
        dmesg_log(70, 65, 84, 32)
    } else {
        volatile_write(0x4700C048, 0)
    }
}

fn fat_mounted() -> i64 {
    volatile_read(0x4700C048)
}

fn cmd_is_mount() -> i64 {
    let len = cmd_len()
    if len != 5 { 0 }
    else { if cmd_char(0) == 109 { if cmd_char(1) == 111 { if cmd_char(4) == 116 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_mount() {
    // Probe virtio-blk if not already initialized
    if volatile_read(0x4700D018) == 0 {
        virtio_probe()
        if volatile_read(0x4700D000) != 0 {
            virtio_init()
            if volatile_read(0x4700D018) == 1 {
                virtio_load_disk()
            }
        }
    }
    fat_init_disk()
    if fat_mounted() == 1 {
        let entries = volatile_read(0x4700C028)
        print("FAT ")
        print_num(entries)
        println(" entries")
        if volatile_read(0x4700D018) == 1 {
            println("virtio")
        }
    } else {
        println("No disk")
    }
}

fn cmd_is_lsfat() -> i64 {
    let len = cmd_len()
    if len != 5 { 0 }
    else { if cmd_char(0) == 108 { if cmd_char(1) == 115 { if cmd_char(2) == 102 { if cmd_char(3) == 97 { if cmd_char(4) == 116 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_lsfat() {
    if fat_mounted() == 0 {
        println("Not mount")
    } else {
        let base = volatile_read(0x4700C000)
        let root = volatile_read(0x4700C038)
        let entries = volatile_read(0x4700C028)
        let mut i = 0
        while i < entries {
            let entry = base + root + i * 32
            let first = volatile_read_u8(entry)
            if first != 0 {
                if first != 0xE5 {
                    let attr = volatile_read_u8(entry + 11)
                    if attr != 0x0F {
                        // Type
                        if (attr & 0x10) != 0 {
                            print("d ")
                        } else {
                            print("- ")
                        }
                        // Size
                        let size = fat_read_u32(entry + 28)
                        print_num(size)
                        print(" ")
                        // Name (8.3)
                        let mut j = 0
                        while j < 8 {
                            let c = volatile_read_u8(entry + j)
                            if c != 32 {
                                if c >= 65 {
                                    if c <= 90 {
                                        putc(c + 32)
                                    } else {
                                        putc(c)
                                    }
                                } else {
                                    putc(c)
                                }
                            }
                            j = j + 1
                        }
                        // Extension
                        let ext0 = volatile_read_u8(entry + 8)
                        if ext0 != 32 {
                            print(".")
                            let mut k = 8
                            while k < 11 {
                                let ec = volatile_read_u8(entry + k)
                                if ec != 32 {
                                    if ec >= 65 {
                                        if ec <= 90 {
                                            putc(ec + 32)
                                        } else {
                                            putc(ec)
                                        }
                                    } else {
                                        putc(ec)
                                    }
                                }
                                k = k + 1
                            }
                        }
                        nl()
                    }
                }
            }
            i = i + 1
        }
    }
}

fn cmd_is_catfat() -> i64 {
    let len = cmd_len()
    if len < 8 { 0 }
    else { if cmd_char(0) == 99 { if cmd_char(1) == 97 { if cmd_char(2) == 116 { if cmd_char(3) == 102 { if cmd_char(4) == 97 { if cmd_char(5) == 116 { if cmd_char(6) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_catfat() {
    if fat_mounted() == 0 {
        putc(78) putc(111) putc(116) putc(32) putc(109) putc(111) putc(117) putc(110) putc(116)
        nl()
    } else {
        let base = volatile_read(0x4700C000)
        let root = volatile_read(0x4700C038)
        let entries = volatile_read(0x4700C028)
        let data_start = volatile_read(0x4700C040)
        let bps = volatile_read(0x4700C008)
        let spc = volatile_read(0x4700C010)
        // Match filename from command (convert to uppercase 8.3)
        let mut found = 0
        let mut i = 0
        while i < entries {
            let entry = base + root + i * 32
            let first = volatile_read_u8(entry)
            if first != 0 {
                if first != 0xE5 {
                    let attr = volatile_read_u8(entry + 11)
                    if (attr & 0x10) == 0 {
                        if attr != 0x0F {
                            // Simple match: compare first chars
                            let len = cmd_len()
                            let mut match_ok = 1
                            let mut ci = 7
                            let mut fi = 0
                            while ci < len {
                                let cc = cmd_char(ci)
                                let mut uc = cc
                                if cc >= 97 {
                                    if cc <= 122 {
                                        uc = cc - 32
                                    }
                                }
                                if cc == 46 {
                                    // Skip to extension (pos 8)
                                    fi = 8
                                } else {
                                    let fc = volatile_read_u8(entry + fi)
                                    if fc != uc {
                                        match_ok = 0
                                        ci = len
                                    }
                                    fi = fi + 1
                                }
                                ci = ci + 1
                            }
                            if match_ok == 1 {
                                found = 1
                                let size = fat_read_u32(entry + 28)
                                let cluster = fat_read_u16(entry + 26)
                                let offset = base + data_start + (cluster - 2) * spc * bps
                                let mut k = 0
                                while k < size {
                                    putc(volatile_read_u8(offset + k))
                                    k = k + 1
                                }
                            }
                        }
                    }
                }
            }
            i = i + 1
        }
        if found == 0 {
            putc(63) nl()
        }
    }
}

fn cmd_is_df() -> i64 {
    let len = cmd_len()
    if len != 2 { 0 }
    else { if cmd_char(0) == 100 { if cmd_char(1) == 102 { 1 } else { 0 } } else { 0 } }
}

fn cmd_df() {
    if fat_mounted() == 1 {
        let bps = volatile_read(0x4700C008)
        let total = volatile_read(0x4700C028)
        print("FAT: ")
        // Count used entries
        let base = volatile_read(0x4700C000)
        let root = volatile_read(0x4700C038)
        let mut used = 0
        let mut i = 0
        while i < total {
            let entry = base + root + i * 32
            let first = volatile_read_u8(entry)
            if first != 0 {
                if first != 0xE5 {
                    let attr = volatile_read_u8(entry + 11)
                    if attr != 0x0F {
                        used = used + 1
                    }
                }
            }
            i = i + 1
        }
        print_num(used)
        putc(47)
        print_num(total)
        println(" ent")
    } else {
        // RAM FS info
        print("RAM: ")
        let mut used = 0
        let mut j = 0
        while j < 16 {
            if volatile_read_u8(0x47008000 + j * 128 + 63) > 0 {
                used = used + 1
            }
            j = j + 1
        }
        print_num(used)
        println("/16")
    }
}

// ═══════════════════════════════════════════════════════════════════
// FAT Write Support (Milestone 1 — S19)
// ═══════════════════════════════════════════════════════════════════

// Write 16-bit little-endian
fn fat_write_u16(addr: i64, val: i64) {
    volatile_write_u8(addr, val & 0xFF)
    volatile_write_u8(addr + 1, (val >> 8) & 0xFF)
}

// Write 32-bit little-endian
fn fat_write_u32(addr: i64, val: i64) {
    volatile_write_u8(addr, val & 0xFF)
    volatile_write_u8(addr + 1, (val >> 8) & 0xFF)
    volatile_write_u8(addr + 2, (val >> 16) & 0xFF)
    volatile_write_u8(addr + 3, (val >> 24) & 0xFF)
}

// FAT table base address (after reserved sectors)
fn fat_table_addr() -> i64 {
    let base = volatile_read(0x4700C000)
    let reserved = volatile_read(0x4700C018)
    let bps = volatile_read(0x4700C008)
    base + reserved * bps
}

// Read FAT16 entry for cluster
fn fat_read_entry(cluster: i64) -> i64 {
    fat_read_u16(fat_table_addr() + cluster * 2)
}

// Write FAT16 entry for cluster
fn fat_write_entry(cluster: i64, val: i64) {
    fat_write_u16(fat_table_addr() + cluster * 2, val)
}

// Total sectors from BPB
fn fat_total_sectors() -> i64 {
    let base = volatile_read(0x4700C000)
    let ts16 = fat_read_u16(base + 19)
    let mut total = ts16
    if ts16 == 0 {
        total = fat_read_u32(base + 32)
    }
    total
}

// Max valid cluster number
fn fat_max_cluster() -> i64 {
    let bps = volatile_read(0x4700C008)
    let spc = volatile_read(0x4700C010)
    let data_start = volatile_read(0x4700C040)
    let total = fat_total_sectors()
    let data_sectors = total - data_start / bps
    data_sectors / spc + 2
}

// Find first free cluster (FAT entry == 0x0000)
// Returns cluster number, or 0 if disk full
fn fat_find_free_cluster() -> i64 {
    let max = fat_max_cluster()
    let mut c = 2
    let mut result = 0
    while c < max {
        if result == 0 {
            if fat_read_entry(c) == 0 {
                result = c
                c = max
            }
        }
        c = c + 1
    }
    result
}

// Find first free root dir entry (first byte 0x00 or 0xE5)
// Returns absolute address, or 0 if full
fn fat_find_free_dir_entry() -> i64 {
    let base = volatile_read(0x4700C000)
    let root = volatile_read(0x4700C038)
    let entries = volatile_read(0x4700C028)
    let mut i = 0
    let mut result = 0
    while i < entries {
        if result == 0 {
            let entry = base + root + i * 32
            let first = volatile_read_u8(entry)
            if first == 0 {
                result = entry
                i = entries
            } else {
                if first == 0xE5 {
                    result = entry
                    i = entries
                }
            }
        }
        i = i + 1
    }
    result
}

// Convert char to uppercase
fn fat_to_upper(c: i64) -> i64 {
    let mut r = c
    if c >= 97 {
        if c <= 122 {
            r = c - 32
        }
    }
    r
}

// Fill dir entry bytes [0..11) with 8.3 name from cmd buffer [start..end)
fn fat_fill_name(entry: i64, start: i64, end: i64) {
    let mut j = 0
    while j < 11 {
        volatile_write_u8(entry + j, 32)
        j = j + 1
    }
    let mut ci = start
    let mut fi = 0
    while ci < end {
        let c = cmd_char(ci)
        if c == 46 {
            fi = 8
        } else {
            if fi < 11 {
                volatile_write_u8(entry + fi, fat_to_upper(c))
                fi = fi + 1
            }
        }
        ci = ci + 1
    }
}

// Match dir entry name against cmd buffer [start..end)
// Uses scratch area at 0x4700C100 for comparison
fn fat_name_match(entry: i64, start: i64, end: i64) -> i64 {
    let scratch = 0x4700C100
    fat_fill_name(scratch, start, end)
    let mut ok = 1
    let mut j = 0
    while j < 11 {
        if ok == 1 {
            if volatile_read_u8(entry + j) != volatile_read_u8(scratch + j) {
                ok = 0
            }
        }
        j = j + 1
    }
    ok
}

// Write cmd buffer data [start..len) to cluster, return bytes written
fn fat_write_data(cluster: i64, start: i64) -> i64 {
    let base = volatile_read(0x4700C000)
    let data_area = volatile_read(0x4700C040)
    let bps = volatile_read(0x4700C008)
    let spc = volatile_read(0x4700C010)
    let addr = base + data_area + (cluster - 2) * spc * bps
    let max = spc * bps
    let len = cmd_len()
    let mut size = 0
    let mut i = start
    while i < len {
        if size < max {
            volatile_write_u8(addr + size, cmd_char(i))
            size = size + 1
        }
        i = i + 1
    }
    size
}

// Free cluster chain in FAT table
fn fat_free_chain(cluster: i64) {
    let mut c = cluster
    let mut count = 0
    while c >= 2 {
        if count > 1000 {
            c = 0
        } else {
            let next = fat_read_entry(c)
            fat_write_entry(c, 0)
            if next >= 0xFFF8 {
                c = 0
            } else {
                c = next
            }
            count = count + 1
        }
    }
}

// Delete dir entry + free its cluster chain
fn fat_delete_entry(entry: i64) {
    let cluster = fat_read_u16(entry + 26)
    if cluster >= 2 {
        fat_free_chain(cluster)
    }
    volatile_write_u8(entry, 0xE5)
}

// Create file: dir entry + write data + update FAT
fn fat_create_file(name_start: i64, name_end: i64, data_idx: i64) {
    let entry = fat_find_free_dir_entry()
    if entry == 0 {
        // "Full"
        putc(70) putc(117) putc(108) putc(108) nl()
    } else {
        let cluster = fat_find_free_cluster()
        if cluster == 0 {
            putc(70) putc(117) putc(108) putc(108) nl()
        } else {
            fat_fill_name(entry, name_start, name_end)
            volatile_write_u8(entry + 11, 0x20)
            let mut j = 12
            while j < 26 {
                volatile_write_u8(entry + j, 0)
                j = j + 1
            }
            fat_write_u16(entry + 26, cluster)
            let size = fat_write_data(cluster, data_idx)
            fat_write_u32(entry + 28, size)
            fat_write_entry(cluster, 0xFFFF)
            // "OK"
            putc(79) putc(75) nl()
        }
    }
}

// "writefat <name> <data>" — create file on FAT disk
fn cmd_is_writefat() -> i64 {
    let len = cmd_len()
    if len < 10 { 0 }
    else { if cmd_char(0) == 119 { if cmd_char(1) == 114 { if cmd_char(2) == 105 { if cmd_char(3) == 116 { if cmd_char(4) == 101 { if cmd_char(5) == 102 { if cmd_char(6) == 97 { if cmd_char(7) == 116 { if cmd_char(8) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_writefat() {
    if fat_mounted() == 0 {
        putc(78) putc(111) putc(116) putc(32) putc(109) putc(111) putc(117) putc(110) putc(116)
        nl()
    } else {
        let len = cmd_len()
        // Find end of filename (first space after index 9)
        let mut name_end = 0
        let mut i = 9
        while i < len {
            if name_end == 0 {
                if cmd_char(i) == 32 {
                    name_end = i
                    i = len
                }
            }
            i = i + 1
        }
        if name_end == 0 {
            name_end = len
        }
        let mut data_start = len
        if name_end < len {
            data_start = name_end + 1
        }
        fat_create_file(9, name_end, data_start)
    }
}

// "rmfat <name>" — delete file from FAT disk
fn cmd_is_rmfat() -> i64 {
    let len = cmd_len()
    if len < 7 { 0 }
    else { if cmd_char(0) == 114 { if cmd_char(1) == 109 { if cmd_char(2) == 102 { if cmd_char(3) == 97 { if cmd_char(4) == 116 { if cmd_char(5) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_rmfat() {
    if fat_mounted() == 0 {
        putc(78) putc(111) putc(116) putc(32) putc(109) putc(111) putc(117) putc(110) putc(116)
        nl()
    } else {
        let base = volatile_read(0x4700C000)
        let root = volatile_read(0x4700C038)
        let entries = volatile_read(0x4700C028)
        let name_start = 6
        let name_end = cmd_len()
        let mut found = 0
        let mut i = 0
        while i < entries {
            if found == 0 {
                let entry = base + root + i * 32
                let first = volatile_read_u8(entry)
                if first != 0 {
                    if first != 0xE5 {
                        let attr = volatile_read_u8(entry + 11)
                        if attr != 0x0F {
                            if fat_name_match(entry, name_start, name_end) == 1 {
                                found = 1
                                fat_delete_entry(entry)
                                putc(79) putc(75) nl()
                            }
                        }
                    }
                }
            }
            i = i + 1
        }
        if found == 0 {
            putc(63) nl()
        }
    }
}

// ═══════════════════════════════════════════════════════════════════
// VirtIO Block Device Driver (Milestone 1 — S16/S17)
//
// QEMU virt machine: virtio MMIO at 0x0a000000-0x0a003e00
// Usage: qemu -drive file=fat.img,format=raw,if=virtio
//
// Driver state at 0x4700D000:
//   [0]  MMIO base (0 = not found)
//   [8]  capacity (sectors)
//   [16] queue size
//   [24] initialized (1 = ready)
//   [32] avail ring index
//   [40] used ring last index
//
// VirtQueue memory (v1 legacy contiguous layout):
//   0x48000000: Descriptor table (16 × 16 bytes = 256)
//   0x48000100: Available ring (after descriptors)
//   0x48001000: Used ring (page-aligned after avail)
//   0x48003000: Request header (16 bytes)
//   0x48004200: Status byte
// ═══════════════════════════════════════════════════════════════════

// MMIO 32-bit access via volatile_read_u32 / volatile_write_u32 builtins
fn mmio_read32(addr: i64) -> i64 {
    volatile_read_u32(addr)
}

fn mmio_write32(addr: i64, val: i64) {
    volatile_write_u32(addr, val)
}

// Scan virtio MMIO for block device (DeviceID == 2)
// QEMU maps devices at highest slots first, so scan high-to-low
fn virtio_probe() {
    let mut addr = 0x0a003e00
    let mut found = 0
    while addr >= 0x0a000000 {
        if found == 0 {
            let magic = mmio_read32(addr)
            if magic == 0x74726976 {
                let devid = mmio_read32(addr + 8)
                if devid == 2 {
                    found = addr
                    addr = 0
                }
            }
        }
        if addr > 0 {
            addr = addr - 0x200
        } else {
            addr = 0
        }
    }
    volatile_write(0x4700D000, found)
}

// Reset + set ACKNOWLEDGE + DRIVER
fn virtio_reset(base: i64) {
    mmio_write32(base + 0x70, 0)
    mmio_write32(base + 0x70, 1)
    mmio_write32(base + 0x70, 3)
}

// Negotiate features (v1 legacy: accept minimal set only)
fn virtio_negotiate(base: i64) {
    mmio_read32(base + 0x10)
    // Accept no optional features — basic block I/O only
    mmio_write32(base + 0x20, 0)
}

// Setup virtqueue 0 (v1 legacy: QueuePFN)
fn virtio_setup_queue(base: i64) {
    // Select queue 0
    mmio_write32(base + 0x30, 0)
    let qmax = mmio_read32(base + 0x34)
    let mut qsize = 16
    if qmax < 16 { qsize = qmax }
    mmio_write32(base + 0x38, qsize)
    volatile_write(0x4700D010, qsize)
    // Set alignment
    mmio_write32(base + 0x3C, 4096)
    // Zero descriptor table (256 bytes at 0x48000000)
    let mut i = 0
    while i < 256 { volatile_write_u8(0x48000000 + i, 0)  i = i + 1 }
    // Zero available ring (64 bytes at 0x48000100)
    i = 0
    while i < 64 { volatile_write_u8(0x48000100 + i, 0)  i = i + 1 }
    // Zero used ring (256 bytes at 0x48001000)
    i = 0
    while i < 256 { volatile_write_u8(0x48001000 + i, 0)  i = i + 1 }
    // Set queue PFN (physical_address / page_size)
    mmio_write32(base + 0x40, 0x48000)
}

// Initialize virtio-blk device (v1 legacy: no FEATURES_OK)
fn virtio_init() {
    let base = volatile_read(0x4700D000)
    if base != 0 {
        virtio_reset(base)
        // Set GuestPageSize FIRST to put QEMU in v1 legacy mode
        mmio_write32(base + 0x28, 4096)
        virtio_negotiate(base)
        virtio_setup_queue(base)
        // DRIVER_OK = ACKNOWLEDGE(1) + DRIVER(2) + DRIVER_OK(4) = 7
        mmio_write32(base + 0x70, 7)
        let cap = mmio_read32(base + 0x100)
        volatile_write(0x4700D008, cap)
        volatile_write(0x4700D018, 1)
        volatile_write(0x4700D020, 0)
        volatile_write(0x4700D028, 0)
    }
}

// Set virtqueue descriptor entry
// Layout: [0-7] addr, [8-11] len, [12-13] flags, [14-15] next
fn vq_set_desc(idx: i64, addr: i64, len: i64, flags: i64, next: i64) {
    let d = 0x48000000 + idx * 16
    fat_write_u32(d, addr & 0xFFFFFFFF)
    fat_write_u32(d + 4, 0)
    fat_write_u32(d + 8, len)
    fat_write_u16(d + 12, flags)
    fat_write_u16(d + 14, next)
}

// Perform virtio-blk I/O (read or write)
// is_write: 0=read, 1=write; bytes: total data size
fn virtio_do_io(sector: i64, buf: i64, bytes: i64, is_write: i64) {
    let base = volatile_read(0x4700D000)
    let hdr = 0x48003000
    let status_addr = 0x48004200
    // Fill request header
    fat_write_u32(hdr, is_write)
    fat_write_u32(hdr + 4, 0)
    fat_write_u32(hdr + 8, sector & 0xFFFFFFFF)
    fat_write_u32(hdr + 12, 0)
    volatile_write_u8(status_addr, 0xFF)
    // Descriptor 0: header (device reads)
    vq_set_desc(0, hdr, 16, 1, 1)
    // Descriptor 1: data buffer
    let mut d1_flags = 3
    if is_write == 1 { d1_flags = 1 }
    vq_set_desc(1, buf, bytes, d1_flags, 2)
    // Descriptor 2: status (device writes)
    vq_set_desc(2, status_addr, 1, 2, 0)
    // Add to available ring (v1: at 0x48000100)
    let avail = 0x48000100
    let idx = volatile_read(0x4700D020)
    let qsize = volatile_read(0x4700D010)
    fat_write_u16(avail + 4 + (idx & (qsize - 1)) * 2, 0)
    asm!("dmb ish")
    fat_write_u16(avail + 2, (idx + 1) & 0xFFFF)
    volatile_write(0x4700D020, idx + 1)
    // Notify device (MMIO register)
    mmio_write32(base + 0x50, 0)
    // Poll used ring for completion (v1: at 0x48001000)
    let used = 0x48001000
    let last = volatile_read(0x4700D028)
    let mut done = 0
    let mut spin = 0
    while done == 0 {
        asm!("dmb ish")
        let used_idx = fat_read_u16(used + 2)
        if used_idx != (last & 0xFFFF) {
            done = 1
        }
        spin = spin + 1
        if spin > 10000000 { done = 1 }
    }
    volatile_write(0x4700D028, last + 1)
}

// Load entire disk from virtio-blk into memory at 0x44000000
// Reads in 64KB chunks (128 sectors) for reliability
fn virtio_load_disk() {
    let cap = volatile_read(0x4700D008)
    let dest = 0x44000000
    let chunk = 128
    let mut s = 0
    while s < cap {
        let mut n = chunk
        if s + n > cap { n = cap - s }
        virtio_do_io(s, dest + s * 512, n * 512, 0)
        s = s + n
    }
}

// Write back entire disk from memory to virtio-blk
fn virtio_save_disk() {
    let cap = volatile_read(0x4700D008)
    let src = 0x44000000
    let chunk = 128
    let mut s = 0
    while s < cap {
        let mut n = chunk
        if s + n > cap { n = cap - s }
        virtio_do_io(s, src + s * 512, n * 512, 1)
        s = s + n
    }
}

