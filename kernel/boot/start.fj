fn cmd_ls() {
    let mut slot = 0
    let mut count = 0
    while slot < 16 {
        let base = 0x47008000 + slot * 128
        let ftype = volatile_read_u8(base + 63)
        if ftype > 0 {
            if ftype == 2 {
                putc(100)
            } else {
                putc(45)
            }
            putc(32)
            let size = volatile_read(base + 64)
            print_num(size)
            putc(32)
            let mut j = 0
            let mut c = volatile_read_u8(base + j)
            while c != 0 {
                putc(c)
                j = j + 1
                c = volatile_read_u8(base + j)
            }
            nl()
            count = count + 1
        }
        slot = slot + 1
    }
    if count == 0 {
        println("(empty)")
    }
}

