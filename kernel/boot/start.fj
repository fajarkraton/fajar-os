    if len < 7 { 0 }
    else { if cmd_char(0) == 116 { if cmd_char(1) == 111 { if cmd_char(2) == 117 { if cmd_char(3) == 99 { if cmd_char(4) == 104 { if cmd_char(5) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_touch() {
    // "touch <filename>"
    let mut slot = 1
    let mut found = 0
    while slot < 16 {
        if volatile_read_u8(0x47008000 + slot * 128 + 63) == 0 {
            if found == 0 {
                found = 1
                let base = 0x47008000 + slot * 128
                let len = cmd_len()
                let mut i = 6
                let mut j = 0
                while i < len {
                    volatile_write_u8(base + j, cmd_char(i))
                    j = j + 1
                    i = i + 1
                }
                volatile_write_u8(base + j, 0)
                volatile_write_u8(base + 63, 1)
                volatile_write(base + 64, 0)
                volatile_write(base + 72, slot * 256)
            }
        }
        slot = slot + 1
    }
    if found == 0 {
        putc(102) putc(117) putc(108) putc(108) nl()
    }
}

fn cmd_is_rm() -> i64 {
    let len = cmd_len()
    if len < 4 { 0 }
    else { if cmd_char(0) == 114 { if cmd_char(1) == 109 { if cmd_char(2) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_rm() {
    // "rm <filename>" — find and delete
    let len = cmd_len()
    let mut slot = 1
    let mut found = 0
    while slot < 16 {
        let base = 0x47008000 + slot * 128
        let ftype = volatile_read_u8(base + 63)
        if ftype > 0 {
            let mut match_ok = 1
            let mut j = 0
            let mut ni = 3
            while ni < len {
                let fc = volatile_read_u8(base + j)
                if fc != cmd_char(ni) {
                    match_ok = 0
                    ni = len
                }
                j = j + 1
                ni = ni + 1
            }
            if match_ok == 1 {
                if volatile_read_u8(base + j) == 0 {
                    volatile_write_u8(base + 63, 0)
                    found = 1
                }
            }
        }
        slot = slot + 1
    }
    if found == 0 {
        putc(63) nl()
    }
}

