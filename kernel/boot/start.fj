    if len < 5 { 0 }
    else { if cmd_char(0) == 99 { if cmd_char(1) == 109 { if cmd_char(2) == 112 { if cmd_char(3) == 32 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_cmp() {
    // "cmp <addr1> <addr2>" — compare 64 bytes
    let a1 = parse_num_from(4)
    let mut diff = 0
    let mut i = 0
    while i < 64 {
        let b1 = volatile_read_u8(a1 + i)
        let b2 = volatile_read_u8(a1 + 0x100 + i)
        if b1 != b2 {
            diff = diff + 1
        }
        i = i + 1
    }
    if diff == 0 {
        println("==")
    } else {
        print_num(diff)
        println(" diff")
    }
}

fn cmd_is_test() -> i64 {
    let len = cmd_len()
    if len != 4 { 0 }
    else { if cmd_char(0) == 116 { if cmd_char(1) == 101 { if cmd_char(2) == 115 { if cmd_char(3) == 116 { 1 } else { 0 } } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_test() {
    let mut pass = 0
    let mut fail = 0

    // Test 1: timer reads non-zero
    print("1.")
    let f = timer_freq()
    if f > 0 { putc(80) pass = pass + 1 } else { putc(70) fail = fail + 1 }
    nl()

    // Test 2: timer counter increments
    print("2.")
    let t1 = timer_ticks()
    let mut w = 0
    while w < 100 { w = w + 1 }
    let t2 = timer_ticks()
    if t2 > t1 { putc(80) pass = pass + 1 } else { putc(70) fail = fail + 1 }
    nl()

    // Test 3: memory write/read
    print("3.")
    volatile_write(0x47009000, 0xCAFE)
    let v = volatile_read(0x47009000)
    if v == 0xCAFE { putc(80) pass = pass + 1 } else { putc(70) fail = fail + 1 }
    nl()

    // Test 4: EL == 1
    print("4.")
    let mut el = 0
    asm!("mrs x0, CurrentEL", out("x0") el)
    let level = (el >> 2) & 3
    if level == 1 { putc(80) pass = pass + 1 } else { putc(70) fail = fail + 1 }
    nl()

    // Test 5: VBAR set (non-zero)
    print("5.")
    let mut vbar = 0
    asm!("mrs x0, VBAR_EL1", out("x0") vbar)
    if vbar > 0 { putc(80) pass = pass + 1 } else { putc(70) fail = fail + 1 }
    nl()

    // Summary
    print_num(pass)
    print("/")
    print_num(pass + fail)
    println(" pass")
}

fn cmd_is_top() -> i64 {
    let len = cmd_len()
    if len != 3 { 0 }
    else { if cmd_char(0) == 116 { if cmd_char(1) == 111 { if cmd_char(2) == 112 { 1 } else { 0 } } else { 0 } } else { 0 } }
}

fn cmd_top() {
    let total_irqs = volatile_read(0x47001020)
    println("PID ST  TICKS  CPU%")
    println("--- --  -----  ----")
    let mut p = 0
    while p < MAX_PROCS {
        let base = PROC_TABLE_BASE + p * PROC_SLOT_SIZE
        let st = volatile_read(base + 8)
        if st != STATE_FREE {
            if p < 10 { print(" ") }
            print_num(p)
            print("  ")
            if st == STATE_READY { putc(82) }
            if st == STATE_RUNNING { putc(42) }
            if st == STATE_BLOCKED { putc(66) }
            if st == STATE_TERMINATED { putc(68) }
            print("   ")
            let ticks = volatile_read(base + 80)
            print_num(ticks)
            if total_irqs > 0 {
                print("    ")
                let pct = ticks * 100 / total_irqs
                print_num(pct)
                print("%")
            }
            nl()
        }
        p = p + 1
    }
    print("Up: ")
    let ms = uptime_ms()
    print_num(ms)
    print("ms  IRQs: ")
    print_num(total_irqs)
    nl()
}

