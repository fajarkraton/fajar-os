fn cmd_head() {
    // "head <addr>" — show first 8 bytes as text
    let addr = parse_num_from(5)
    let mut i = 0
    while i < 8 {
        let b = volatile_read_u8(addr + i)
        if b >= 32 {
            if b < 127 {
                putc(b)
            } else {
