fn cmd_bits() {
    // "bits <num>" — show binary representation (16 bits)
    let val = parse_num_from(5)
    let mut bit = 15
    while bit >= 0 {
        let b = (val >> bit) & 1
        putc(48 + b)
        if (bit & 3) == 0 {
            if bit > 0 {
                putc(95)
            }
        }
        bit = bit - 1
    }
    print(" (")
